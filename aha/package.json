{
  "name": "aha",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "bunx --bun astro dev",
    "build": "bunx --bun astro build",
    "fmt": "bunx --bun astro sync && bunx --bun prettier --write 'src/**/*.{astro,ts}'",
    "gen:go": "bun run scripts/gen-go.ts --all",
    "gen:css": "bunx @tailwindcss/cli -i ./src/index.css -o ../goth/static/css/aha.css --minify",
    "gen:static": "bun run scripts/bundle-static.ts && bun run gen:css",
    "gen:init": "rm -f ../goth/internal/features/*_gen.go ../goth/internal/features/*_gen.templ ../goth/internal/features/*_gen_templ.go ../goth/internal/features/*_cus_service.go ../goth/internal/features/dao_config.json",
    "gen:all": "bun run gen:go && bun run gen:static && cd ../goth && templ generate && go generate ./... && go fmt ./...",
    "gen:tpl": "bun third-party-license & bun run scripts/gen-licenses.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@nurodev/astro-bun": "^2.1.2",
    "@types/alpinejs": "^3.13.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "alpinejs": "^3.15.8",
    "astro": "^6.0.8",
    "astro-icon": "^1.1.5",
    "drizzle-orm": "^0.45.1",
    "htmx.org": "^2.0.8",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "node-module-license-output": "^1.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.2",
    "vite-node": "^6.0.0"
  },
  "overrides": {
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
