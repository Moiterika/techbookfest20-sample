---
import { tdCell, row, inputStyleSm } from "../../styles/common";
import { unitLabels, type Unit } from "../../features/shared/types/unit";
import Typeahead品目 from "../品目/Typeahead品目.astro";

interface Props {
  section: "output" | "input";
  rowKey: string;
  itemId?: number;
  itemCode?: string;
  itemName?: string;
  quantity?: string;
  unit?: string;
  refBomCode?: string;
  refBomVersion?: string;
}

const {
  section,
  rowKey,
  itemId,
  itemCode,
  itemName,
  quantity = "",
  unit = "pcs",
  refBomCode = "",
  refBomVersion = "",
} = Astro.props;

const lineType = section === "output" ? "2" : "1";
const unitOptions = Object.entries(unitLabels) as [Unit, string][];
const lookupId = `lookup-${rowKey}-itemName`;

const cellSelect =
  "rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 min-w-20";
const removeBtn =
  "inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-error border-none bg-transparent text-sm hover:bg-error/10";
const lookupText = "text-sm text-outline";
---

<tr id={`bom-line-${rowKey}`} class={row}>
  <input type="hidden" name="lineType" value={lineType} />
  <td class={tdCell}>
    <Typeahead品目
      name="lineItemId"
      selectedId={itemId}
      selectedCode={itemCode ?? ""}
      selectedName={itemName ?? ""}
      compact
      hideNameLabel
      lookupTargetId={lookupId}
    />
  </td>
  <td class={tdCell}>
    <span id={lookupId} class={lookupText}>{itemName ?? ""}</span>
  </td>
  <td class={tdCell}>
    <input
      type="number"
      step="0.0001"
      min="0"
      name="lineQuantity"
      value={quantity}
      class={inputStyleSm}
      placeholder="0"
    />
  </td>
  <td class={tdCell}>
    <select name="lineUnit" class={cellSelect}>
      {
        unitOptions.map(([val, label]) => (
          <option value={val} selected={val === unit}>
            {label}
          </option>
        ))
      }
    </select>
  </td>
  {
    section === "input" ? (
      <>
        <td class={tdCell}>
          <input
            type="text"
            name="lineRefBomCode"
            value={refBomCode}
            class={inputStyleSm}
            placeholder="BOMコード"
          />
        </td>
        <td class={tdCell}>
          <input
            type="text"
            name="lineRefBomVersion"
            value={refBomVersion}
            class={inputStyleSm}
            placeholder="版"
          />
        </td>
      </>
    ) : (
      <>
        <input type="hidden" name="lineRefBomCode" value="" />
        <input type="hidden" name="lineRefBomVersion" value="" />
      </>
    )
  }
  <td class={tdCell}>
    <button
      type="button"
      class={removeBtn}
      onclick="this.closest('tr').remove()"
    >
      &times;
    </button>
  </td>
</tr>
