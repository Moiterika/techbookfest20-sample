---
import { tdCell, row, inputStyleSm } from "../../styles/common";
import { unitLabels, type Unit } from "../../features/shared/types/unit";
import Typeahead from "../crud/Typeahead.astro";
import { 品目Typeahead } from "../../features/shared/typeahead-configs";

interface Props {
  section: "output" | "input";
  rowKey: string;
  品目ID?: number;
  品目コード?: string;
  品目名?: string;
  数量?: string;
  単位?: string;
  参照BOMコード?: string;
  参照BOM版?: string;
}

const {
  section,
  rowKey,
  品目ID,
  品目コード,
  品目名,
  数量 = "",
  単位 = "pcs",
  参照BOMコード = "",
  参照BOM版 = "",
} = Astro.props;

const lineType = section === "output" ? "2" : "1";
const unitOptions = Object.entries(unitLabels) as [Unit, string][];
const lookupId = `lookup-${rowKey}-品目名`;

const cellSelect =
  "rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 min-w-20";
const removeBtn =
  "inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-error border-none bg-transparent text-sm hover:bg-error/10";
const lookupText = "text-sm text-outline";
---

<tr id={`bom-line-${rowKey}`} class={row}>
  <input type="hidden" name="line区分" value={lineType} />
  <td class={tdCell}>
    <Typeahead
      config={品目Typeahead}
      name="line品目ID"
      selectedId={品目ID}
      selectedCode={品目コード ?? ""}
      selectedName={品目名 ?? ""}
      compact
      hideNameLabel
      lookupTargetId={lookupId}
    />
  </td>
  <td class={tdCell}>
    <span id={lookupId} class={lookupText}>{品目名 ?? ""}</span>
  </td>
  <td class={tdCell}>
    <input
      type="number"
      step="0.0001"
      min="0"
      name="line数量"
      value={数量}
      class={inputStyleSm}
      placeholder="0"
    />
  </td>
  <td class={tdCell}>
    <select name="line単位" class={cellSelect}>
      {
        unitOptions.map(([val, label]) => (
          <option value={val} selected={val === 単位}>
            {label}
          </option>
        ))
      }
    </select>
  </td>
  {
    section === "input" ? (
      <>
        <td class={tdCell}>
          <input
            type="text"
            name="line参照BOMコード"
            value={参照BOMコード}
            class={inputStyleSm}
            placeholder="BOMコード"
          />
        </td>
        <td class={tdCell}>
          <input
            type="text"
            name="line参照BOM版"
            value={参照BOM版}
            class={inputStyleSm}
            placeholder="版"
          />
        </td>
      </>
    ) : (
      <>
        <input type="hidden" name="line参照BOMコード" value="" />
        <input type="hidden" name="line参照BOM版" value="" />
      </>
    )
  }
  <td class={tdCell}>
    <button
      type="button"
      class={removeBtn}
      onclick="this.closest('tr').remove()"
    >
      &times;
    </button>
  </td>
</tr>
