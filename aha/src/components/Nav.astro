---
interface Props {
  current?: "home" | "items" | "transactions" | "transaction-types" | "boms";
}

const { current } = Astro.props;

const nav = "flex gap-2 mb-6";
const link =
  "text-sm py-2 px-4 rounded-lg font-semibold no-underline transition-all duration-200 text-primary hover:bg-surface-container-high";
const linkActive =
  "text-sm py-2 px-4 rounded-lg font-semibold no-underline transition-all duration-200 bg-gradient-to-br from-primary to-primary-dark text-white pointer-events-none";
---

<nav class={nav}>
  <a href="/" class={current === "home" ? linkActive : link}>ホーム</a>
  <a href="/品目" class={current === "items" ? linkActive : link}>品目管理</a>
  <a href="/取引" class={current === "transactions" ? linkActive : link}
    >取引管理</a
  >
  <a
    href="/取引区分"
    class={current === "transaction-types" ? linkActive : link}>取引区分管理</a
  >
  <a href="/BOM" class={current === "boms" ? linkActive : link}>BOM管理</a>
</nav>
