---
import { pageContainer, pageTitle } from "../styles/common";
import Nav from "./Nav.astro";

const grid = "grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-6";
const cardLink =
  "block p-6 rounded-xl bg-white no-underline transition-all duration-200 hover:bg-surface-container-high hover:-translate-y-0.5";
const cardHeading = "text-lg font-bold text-primary mb-2";
const cardDesc = "text-sm text-on-surface-variant leading-relaxed";
---

<div class={pageContainer}>
  <Nav current="home" />
  <h1 class={pageTitle}>aha</h1>

  <div class={grid}>
    <a href="/品目" class={cardLink}>
      <h2 class={cardHeading}>品目管理</h2>
      <p class={cardDesc}>品目の登録・編集・削除を行います。</p>
    </a>
    <a href="/取引" class={cardLink}>
      <h2 class={cardHeading}>取引管理</h2>
      <p class={cardDesc}>取引の登録・編集・削除を行います。</p>
    </a>
    <a href="/取引区分" class={cardLink}>
      <h2 class={cardHeading}>取引区分管理</h2>
      <p class={cardDesc}>取引区分の登録・編集・削除を行います。</p>
    </a>
    <a href="/BOM" class={cardLink}>
      <h2 class={cardHeading}>BOM管理</h2>
      <p class={cardDesc}>BOMの登録・編集・削除を行います。</p>
    </a>
  </div>
</div>
