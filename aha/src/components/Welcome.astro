---
import { css } from "../../styled-system/css";
import { pageContainer, pageTitle } from "../styles/common.css";
import Nav from "./Nav.astro";

const grid = css({
  display: "grid",
  gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))",
  gap: "6",
});

const cardLink = css({
  display: "block",
  p: "6",
  rounded: "xl",
  bg: "white",
  textDecoration: "none",
  transition: "all 0.2s",
  _hover: { bg: "#dee9fd", transform: "translateY(-2px)" },
});

const cardHeading = css({
  fontSize: "lg",
  fontWeight: "bold",
  color: "#00288e",
  mb: "2",
});

const cardDesc = css({
  fontSize: "sm",
  color: "#444653",
  lineHeight: "1.6",
});
---

<div class={pageContainer}>
  <Nav current="home" />
  <h1 class={pageTitle}>aha</h1>

  <div class={grid}>
    <a href="/items" class={cardLink}>
      <h2 class={cardHeading}>品目管理</h2>
      <p class={cardDesc}>品目の登録・編集・削除を行います。</p>
    </a>
    <a href="/transactions" class={cardLink}>
      <h2 class={cardHeading}>取引管理</h2>
      <p class={cardDesc}>取引の登録・編集・削除を行います。</p>
    </a>
  </div>
</div>
