---
import { css } from "../../../styled-system/css";
import { tdCell, row } from "../../styles/common.css";
import { Icon } from "astro-icon/components";
import CrudPagination from "../crud/CrudPagination.astro";

interface Props {
  records: { id: number; code: string; version: string; name: string }[];
  currentPage?: number;
  totalPages?: number;
  pageSize?: number;
  extraParams?: Record<string, string>;
}

const {
  records,
  currentPage = 1,
  totalPages = 1,
  pageSize = 20,
  extraParams = {},
} = Astro.props;

const emptyCell = css({ textAlign: "center", py: "8", color: "#757684" });

const actionsCell = css({
  py: "4",
  px: "6",
  textAlign: "right",
});

const actionsRow = css({
  display: "flex",
  alignItems: "center",
  justifyContent: "flex-end",
  gap: "2",
});

const editBtn = css({
  display: "inline-flex",
  alignItems: "center",
  gap: "1",
  color: "#00288e",
  fontSize: "xs",
  fontWeight: "bold",
  px: "2",
  py: "1",
  rounded: "md",
  cursor: "pointer",
  border: "none",
  bg: "transparent",
  textDecoration: "none",
  _hover: { bg: "rgba(0, 40, 142, 0.1)" },
});

const kebabBtn = css({
  display: "inline-flex",
  alignItems: "center",
  justifyContent: "center",
  w: "7",
  h: "7",
  rounded: "full",
  cursor: "pointer",
  color: "#757684",
  border: "none",
  bg: "transparent",
  _hover: { color: "#121c2a", bg: "#eff3ff" },
});

const kebabMenu = css({
  position: "absolute",
  right: "0",
  top: "100%",
  zIndex: 20,
  mt: "1",
  bg: "white",
  rounded: "lg",
  boxShadow: "0 10px 30px -5px rgba(18, 28, 42, 0.08)",
  py: "1",
  minW: "120px",
});

const kebabItem = css({
  display: "flex",
  alignItems: "center",
  gap: "2",
  w: "full",
  textAlign: "left",
  px: "3",
  py: "2",
  fontSize: "sm",
  cursor: "pointer",
  color: "#ba1a1a",
  border: "none",
  bg: "transparent",
  _hover: { bg: "rgba(255, 218, 214, 0.3)" },
});
---

{
  records.length === 0 ? (
    <tr>
      <td colspan="4" class={emptyCell}>
        BOMがありません
      </td>
    </tr>
  ) : (
    records.map((r) => (
      <tr id={`bom-${r.id}`} class={row}>
        <td class={tdCell}>{r.code}</td>
        <td class={tdCell}>{r.version}</td>
        <td class={tdCell}>{r.name}</td>
        <td class={actionsCell}>
          <div class={actionsRow}>
            <a href={`/boms/${r.id}`} class={editBtn}>
              <Icon
                name="heroicons:pencil-square"
                class={css({ w: "3.5", h: "3.5" })}
              />
              編集
            </a>
            <div
              class={css({ position: "relative" })}
              x-data="{ menuOpen: false }"
              @click.outside="menuOpen = false"
            >
              <button
                class={kebabBtn}
                @click="menuOpen = !menuOpen"
                type="button"
              >
                <Icon
                  name="heroicons:ellipsis-vertical-solid"
                  class={css({ w: "5", h: "5" })}
                />
              </button>
              <div class={kebabMenu} x-show="menuOpen" x-transition x-cloak>
                <button
                  class={kebabItem}
                  hx-delete={`/api/boms/${r.id}`}
                  hx-target={`#bom-${r.id}`}
                  hx-swap="outerHTML swap:0.3s"
                  hx-confirm={`「${r.name}」を削除しますか？`}
                  @click="menuOpen = false"
                >
                  <Icon
                    name="heroicons:trash"
                    class={css({ w: "4", h: "4" })}
                  />
                  削除
                </button>
              </div>
            </div>
          </div>
        </td>
      </tr>
    ))
  )
}

<CrudPagination
  currentPage={currentPage}
  totalPages={totalPages}
  pageSize={pageSize}
  baseUrl="/api/boms"
  bodyTargetId="boms-body"
  paginationId="boms-pagination"
  extraParams={extraParams}
  oob
/>
