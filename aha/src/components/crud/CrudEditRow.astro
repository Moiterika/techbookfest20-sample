---
import type { Column, EntityConfig } from "./types";
import {
  button,
  tdCell,
  inputStyleSm,
  row,
  flexRow,
} from "../../styles/common";
import Typeahead from "./Typeahead.astro";
import { 品目Typeahead } from "../../features/shared/typeahead-configs";

interface Props {
  record: Record<string, any>;
  columns: Column[];
  entity: EntityConfig;
}

const { record, columns, entity } = Astro.props;
const rowId = `${entity.idPrefix}-${record.id}`;
const formId = `edit-${entity.idPrefix}-${record.id}`;

// 編集行レベルの Alpine x-data
const alpineData = entity.alpineInitEditRow
  ? entity.alpineInitEditRow(record)
  : undefined;

/** カラムの minWidth を反映した style 属性 */
function cellStyle(col: Column): string | undefined {
  return col.minWidth ? `min-width:${col.minWidth}` : undefined;
}

// itemCode/typeahead 列のバリデーション式
function buildBeforeRequest(): string | undefined {
  const itemCol = columns.find(
    (c) => c.type === "itemCode" || c.type === "typeahead",
  );
  if (!itemCol) return undefined;
  const valueName = (itemCol as any).valueName ?? "品目ID";
  return `
    const itemId = document.querySelector('[form=${formId}][name=${valueName}]');
    if (!itemId || !itemId.value) {
      event.preventDefault();
      alert('品目を選択してください');
    }
  `;
}
---

<tr id={rowId} class={row} {...alpineData ? { "x-data": alpineData } : {}}>
  <td class="py-4 px-6"></td>
  {
    columns.map((col) => {
      const type = col.type ?? "text";
      const val = record[col.key];

      if (type === "actions") {
        return (
          <td class={tdCell}>
            <div class={flexRow}>
              <form
                id={formId}
                hx-put={`${entity.baseUrl}/${record.id}`}
                hx-target={`#${rowId}`}
                hx-swap="outerHTML"
                {...(buildBeforeRequest()
                  ? { "hx-on--before-request": buildBeforeRequest() }
                  : {})}
              >
                <button type="submit" class={button({ intent: "primary" })}>
                  保存
                </button>
              </form>
              <button
                hx-get={entity.baseUrl}
                hx-target={`#${entity.bodyTargetId}`}
                hx-swap="innerHTML"
                class={button({ intent: "secondary" })}
              >
                キャンセル
              </button>
            </div>
          </td>
        );
      }

      if (type === "barcode") {
        const escaped = (val ?? "").toString().replace(/'/g, "\\'");
        return (
          <td
            class={tdCell}
            style={cellStyle(col)}
            x-data={`{ barcodeVal: '${escaped}' }`}
          >
            <input
              name={col.key}
              x-model="barcodeVal"
              form={formId}
              class={inputStyleSm}
            />
            <react-barcode x-bind:value="barcodeVal" />
          </td>
        );
      }

      if (type === "itemCode" || type === "typeahead") {
        const valueName = (col as any).valueName ?? "品目ID";
        const lookupCol = columns.find((c) => c.type === "readonlyLookup");
        const lookupId = lookupCol
          ? `lookup-${rowId}-${lookupCol.key}`
          : undefined;
        return (
          <td class={tdCell} style={cellStyle(col)}>
            <Typeahead
              config={品目Typeahead}
              name={valueName}
              selectedId={record[valueName]}
              selectedCode={val ?? ""}
              selectedName={record.品目名 ?? ""}
              formId={formId}
              compact
              hideNameLabel
              lookupTargetId={lookupId}
            />
          </td>
        );
      }

      if (type === "readonlyLookup") {
        const lookupId = `lookup-${rowId}-${col.key}`;
        return (
          <td class={tdCell} style={cellStyle(col)}>
            <span id={lookupId} class="text-sm text-outline">
              {val ?? ""}
            </span>
          </td>
        );
      }

      if (type === "computed") {
        const expr = (col as any).expression;
        return (
          <td class={tdCell} style={cellStyle(col)}>
            <span class="font-medium" x-text={`(${expr}).toLocaleString()`} />
          </td>
        );
      }

      if (type === "number") {
        const numCol = col as any;
        return (
          <td class={tdCell} style={cellStyle(col)}>
            <input
              name={col.key}
              type="number"
              value={val}
              form={formId}
              {...(col.required ? { required: true } : {})}
              {...(numCol.min != null ? { min: numCol.min } : {})}
              class={inputStyleSm}
              {...(numCol.alpineModel
                ? { "x-model.number": numCol.alpineModel }
                : {})}
            />
          </td>
        );
      }

      if (type === "date") {
        return (
          <td class={tdCell} style={cellStyle(col)}>
            <input
              name={col.key}
              type="date"
              value={val}
              form={formId}
              {...(col.required ? { required: true } : {})}
              class={inputStyleSm}
            />
          </td>
        );
      }

      if (type === "select") {
        const selCol = col as any;
        return (
          <td class={tdCell} style={cellStyle(col)}>
            <select
              name={col.key}
              form={formId}
              {...(col.required ? { required: true } : {})}
              class={inputStyleSm}
            >
              {selCol.options.map((opt: any) => (
                <option value={opt.value} selected={String(val) === opt.value}>
                  {opt.label}
                </option>
              ))}
            </select>
          </td>
        );
      }

      // text (default)
      if (col.readonlyOnEdit) {
        return (
          <td class={tdCell} style={cellStyle(col)}>
            <span class="text-sm">{val ?? ""}</span>
            <input type="hidden" name={col.key} value={val ?? ""} form={formId} />
          </td>
        );
      }
      return (
        <td class={tdCell} style={cellStyle(col)}>
          <input
            name={col.key}
            value={val ?? ""}
            form={formId}
            {...(col.required ? { required: true } : {})}
            class={inputStyleSm}
          />
        </td>
      );
    })
  }
</tr>
