---
import type { Column, EntityConfig } from "./types";
import {
  button,
  inputStyle,
  labelStyle,
  card,
  cardTitle,
} from "../../styles/common";
import Typeahead from "./Typeahead.astro";
import { 品目Typeahead } from "../../features/shared/typeahead-configs";

interface Props {
  columns: Column[];
  entity: EntityConfig;
}

const { columns, entity } = Astro.props;

// フォームに表示するカラム（actions と readonlyLookup と hideInForm を除く）
const formColumns = columns.filter((col) => {
  const type = col.type ?? "text";
  if (type === "actions") return false;
  if (type === "readonlyLookup") return false;
  if (col.hideInForm) return false;
  return true;
});

const today = new Date().toISOString().slice(0, 10);

// Alpine x-data: alpineInitForm があればそれを使い、なければ空
const xData = entity.alpineInitForm ?? "{}";

// バーコード列がある場合は barcodeVal を x-data に含める
const hasBarcode = columns.some((c) => c.type === "barcode");

const requiredStar = "text-error";
const formLayout = "flex flex-col gap-4";
---

<div
  x-show="open"
  x-transition
  class={card}
  x-data={xData}
  {...entity.formExtraAttrs ?? {}}
>
  <h2 class={cardTitle}>{entity.formTitle}</h2>
  <form
    hx-post={entity.baseUrl}
    hx-target={`#${entity.bodyTargetId}`}
    hx-swap="innerHTML"
    {...entity.formBeforeRequest
      ? { "hx-on--before-request": entity.formBeforeRequest }
      : {}}
    {...entity.formAfterRequest
      ? { "@htmx:after-request": entity.formAfterRequest }
      : {}}
    class={formLayout}
  >
    {
      formColumns.map((col) => {
        const type = col.type ?? "text";

        if (type === "barcode") {
          return (
            <>
              <label class={labelStyle}>
                {col.label}
                <input
                  name={col.key}
                  class={inputStyle}
                  placeholder={col.placeholder ?? ""}
                  x-model="barcodeVal"
                />
              </label>
              <div class="mt-2 flex justify-center">
                <react-barcode x-bind:value="barcodeVal" />
              </div>
            </>
          );
        }

        if (type === "itemCode" || type === "typeahead") {
          const valueName = (col as any).valueName ?? "itemId";
          return (
            <label class={labelStyle}>
              <span>
                {col.label}{" "}
                {col.required && <span class={requiredStar}>*</span>}
              </span>
              <Typeahead config={品目Typeahead} name={valueName} />
            </label>
          );
        }

        if (type === "computed") {
          const expr = (col as any).expression;
          return (
            <div class="text-sm text-on-surface-variant">
              {col.label}: <strong x-text={`(${expr}).toLocaleString()`} /> 円
            </div>
          );
        }

        if (type === "number") {
          const numCol = col as any;
          return (
            <label class={labelStyle}>
              <span>
                {col.label}{" "}
                {col.required && <span class={requiredStar}>*</span>}
              </span>
              <input
                name={col.key}
                type="number"
                {...(col.required ? { required: true } : {})}
                {...(numCol.min != null ? { min: numCol.min } : {})}
                value={col.defaultValue ?? "0"}
                class={inputStyle}
                {...(numCol.alpineModel
                  ? { "x-model.number": numCol.alpineModel }
                  : {})}
              />
            </label>
          );
        }

        if (type === "date") {
          return (
            <label class={labelStyle}>
              <span>
                {col.label}{" "}
                {col.required && <span class={requiredStar}>*</span>}
              </span>
              <input
                name={col.key}
                type="date"
                {...(col.required ? { required: true } : {})}
                value={col.defaultValue ?? today}
                class={inputStyle}
              />
            </label>
          );
        }

        if (type === "select") {
          const selCol = col as any;
          return (
            <label class={labelStyle}>
              <span>
                {col.label}{" "}
                {col.required && <span class={requiredStar}>*</span>}
              </span>
              <select
                name={col.key}
                {...(col.required ? { required: true } : {})}
                class={inputStyle}
              >
                {selCol.options.map((opt: any) => (
                  <option
                    value={opt.value}
                    selected={String(col.defaultValue) === opt.value}
                  >
                    {opt.label}
                  </option>
                ))}
              </select>
            </label>
          );
        }

        // text (default)
        return (
          <label class={labelStyle}>
            <span>
              {col.label} {col.required && <span class={requiredStar}>*</span>}
            </span>
            <input
              name={col.key}
              {...(col.required ? { required: true } : {})}
              class={inputStyle}
              placeholder={col.placeholder ?? ""}
            />
          </label>
        );
      })
    }
    <div class="mt-2">
      <button type="submit" class:list={["btn", button({ intent: "primary" })]}
        >登録する</button
      >
    </div>
  </form>
</div>
