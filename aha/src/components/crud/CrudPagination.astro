---
import { css } from "../../../styled-system/css";

interface Props {
  currentPage: number;
  totalPages: number;
  pageSize: number;
  /** API ベース URL（例: "/api/items"） */
  baseUrl: string;
  /** tbody の id（htmx target） */
  bodyTargetId: string;
  /** ページネーション要素自体の id */
  paginationId: string;
  /** hx-swap-oob を付けるかどうか */
  oob?: boolean;
  /** ページURL に追加するパラメータ（検索クエリ等） */
  extraParams?: Record<string, string>;
}

const {
  currentPage,
  totalPages,
  pageSize,
  baseUrl,
  bodyTargetId,
  paginationId,
  oob = false,
  extraParams = {},
} = Astro.props;

const paginationBar = css({
  display: "flex",
  justifyContent: "space-between",
  alignItems: "center",
  py: "4",
  px: "6",
  bg: "#eff3ff",
  roundedBottom: "xl",
  flexWrap: "wrap",
  gap: "3",
});

const pageBtns = css({
  display: "flex",
  alignItems: "center",
  gap: "1",
});

const pageInfo = css({
  fontSize: "sm",
  fontWeight: "medium",
  color: "#757684",
  ml: "4",
});

const sizeSelector = css({
  display: "flex",
  alignItems: "center",
  gap: "2",
  fontSize: "sm",
  color: "#444653",
});

const activeBtn = css({
  w: "8",
  h: "8",
  display: "flex",
  alignItems: "center",
  justifyContent: "center",
  fontSize: "xs",
  fontWeight: "bold",
  rounded: "lg",
  background: "linear-gradient(135deg, #00288e, #1e40af)",
  color: "white",
  cursor: "default",
});

const inactiveBtn = css({
  w: "8",
  h: "8",
  display: "flex",
  alignItems: "center",
  justifyContent: "center",
  fontSize: "xs",
  fontWeight: "bold",
  rounded: "lg",
  cursor: "pointer",
  color: "#121c2a",
  _hover: { bg: "#dee9fd" },
});

const disabledBtn = css({
  w: "8",
  h: "8",
  display: "flex",
  alignItems: "center",
  justifyContent: "center",
  fontSize: "xs",
  rounded: "lg",
  color: "#c4c5d5",
  cursor: "default",
});

const selectStyle = css({
  bg: "white",
  rounded: "md",
  fontSize: "sm",
  py: "1",
  px: "2",
  color: "#444653",
  border: "none",
  cursor: "pointer",
  outline: "none",
  _focus: {
    boxShadow: "0 0 0 1px #00288e",
  },
});

const oobAttr = oob ? "true" : undefined;
const sizes = [20, 50, 100];

function pageUrl(page: number, size: number) {
  const params = new URLSearchParams({
    page: String(page),
    size: String(size),
  });
  for (const [k, v] of Object.entries(extraParams)) {
    if (v) params.set(k, v);
  }
  return `${baseUrl}?${params}`;
}

const sizeHxVals = JSON.stringify({ page: "1", ...extraParams });
---

<div
  id={paginationId}
  class={paginationBar}
  {...oobAttr ? { "hx-swap-oob": oobAttr } : {}}
>
  <div class={sizeSelector}>
    <span>表示件数:</span>
    <select
      class={selectStyle}
      hx-get={baseUrl}
      hx-target={`#${bodyTargetId}`}
      hx-swap="innerHTML"
      hx-include="this"
      name="size"
      hx-vals={sizeHxVals}
    >
      {
        sizes.map((s) => (
          <option value={s} selected={s === pageSize}>
            {s}件
          </option>
        ))
      }
    </select>
  </div>

  {
    totalPages > 1 ? (
      <div class={pageBtns}>
        {currentPage > 1 ? (
          <button
            hx-get={pageUrl(currentPage - 1, pageSize)}
            hx-target={`#${bodyTargetId}`}
            hx-swap="innerHTML"
            class={inactiveBtn}
          >
            &lsaquo;
          </button>
        ) : (
          <span class={disabledBtn}>&lsaquo;</span>
        )}

        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) =>
          p === currentPage ? (
            <span class={activeBtn}>{p}</span>
          ) : (
            <button
              hx-get={pageUrl(p, pageSize)}
              hx-target={`#${bodyTargetId}`}
              hx-swap="innerHTML"
              class={inactiveBtn}
            >
              {p}
            </button>
          ),
        )}

        {currentPage < totalPages ? (
          <button
            hx-get={pageUrl(currentPage + 1, pageSize)}
            hx-target={`#${bodyTargetId}`}
            hx-swap="innerHTML"
            class={inactiveBtn}
          >
            &rsaquo;
          </button>
        ) : (
          <span class={disabledBtn}>&rsaquo;</span>
        )}

        <span class={pageInfo}>
          {currentPage} / {totalPages} ページ
        </span>
      </div>
    ) : (
      <div class={pageBtns}>
        <span class={pageInfo}>全 {totalPages} ページ</span>
      </div>
    )
  }
</div>
