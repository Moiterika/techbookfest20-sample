---
interface Props {
  currentPage: number;
  totalPages: number;
  pageSize: number;
  /** API ベース URL（例: "/api/items"） */
  baseUrl: string;
  /** tbody の id（htmx target） */
  bodyTargetId: string;
  /** ページネーション要素自体の id */
  paginationId: string;
  /** hx-swap-oob を付けるかどうか */
  oob?: boolean;
  /** ページURL に追加するパラメータ（検索クエリ等） */
  extraParams?: Record<string, string>;
}

const {
  currentPage,
  totalPages,
  pageSize,
  baseUrl,
  bodyTargetId,
  paginationId,
  oob = false,
  extraParams = {},
} = Astro.props;

const paginationBar =
  "flex justify-between items-center py-4 px-6 bg-surface-container-low rounded-b-xl flex-wrap gap-3";
const pageBtns = "flex items-center gap-1";
const pageInfo = "text-sm font-medium text-outline ml-4";
const sizeSelector = "flex items-center gap-2 text-sm text-on-surface-variant";

const activeBtn =
  "w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg bg-gradient-to-br from-primary to-primary-dark text-white cursor-default";
const inactiveBtn =
  "w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg cursor-pointer text-on-surface hover:bg-surface-container-high";
const disabledBtn =
  "w-8 h-8 flex items-center justify-center text-xs rounded-lg text-outline-variant cursor-default";

const selectStyle =
  "bg-white rounded-md text-sm py-1 px-2 text-on-surface-variant border-none cursor-pointer outline-none focus:shadow-[0_0_0_1px_var(--color-primary)]";

const oobAttr = oob ? "true" : undefined;
const sizes = [20, 50, 100];

function pageUrl(page: number, size: number) {
  const params = new URLSearchParams({
    page: String(page),
    size: String(size),
  });
  for (const [k, v] of Object.entries(extraParams)) {
    if (v) params.set(k, v);
  }
  return `${baseUrl}?${params}`;
}

const sizeHxVals = JSON.stringify({ page: "1", ...extraParams });
---

<div
  id={paginationId}
  class={paginationBar}
  {...oobAttr ? { "hx-swap-oob": oobAttr } : {}}
>
  <div class={sizeSelector}>
    <span>表示件数:</span>
    <select
      class={selectStyle}
      hx-get={baseUrl}
      hx-target={`#${bodyTargetId}`}
      hx-swap="innerHTML"
      hx-include="this"
      name="size"
      hx-vals={sizeHxVals}
    >
      {
        sizes.map((s) => (
          <option value={s} selected={s === pageSize}>
            {s}件
          </option>
        ))
      }
    </select>
  </div>

  {
    totalPages > 1 ? (
      <div class={pageBtns}>
        {currentPage > 1 ? (
          <button
            hx-get={pageUrl(currentPage - 1, pageSize)}
            hx-target={`#${bodyTargetId}`}
            hx-swap="innerHTML"
            class={inactiveBtn}
          >
            &lsaquo;
          </button>
        ) : (
          <span class={disabledBtn}>&lsaquo;</span>
        )}

        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) =>
          p === currentPage ? (
            <span class={activeBtn}>{p}</span>
          ) : (
            <button
              hx-get={pageUrl(p, pageSize)}
              hx-target={`#${bodyTargetId}`}
              hx-swap="innerHTML"
              class={inactiveBtn}
            >
              {p}
            </button>
          ),
        )}

        {currentPage < totalPages ? (
          <button
            hx-get={pageUrl(currentPage + 1, pageSize)}
            hx-target={`#${bodyTargetId}`}
            hx-swap="innerHTML"
            class={inactiveBtn}
          >
            &rsaquo;
          </button>
        ) : (
          <span class={disabledBtn}>&rsaquo;</span>
        )}

        <span class={pageInfo}>
          {currentPage} / {totalPages} ページ
        </span>
      </div>
    ) : (
      <div class={pageBtns}>
        <span class={pageInfo}>全 {totalPages} ページ</span>
      </div>
    )
  }
</div>
