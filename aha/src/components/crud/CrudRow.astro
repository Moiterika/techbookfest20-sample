---
import type { Column, EntityConfig } from "./types";
import { css } from "../../../styled-system/css";
import { tdCell, row } from "../../styles/common.css";
import { Icon } from "astro-icon/components";

interface Props {
  record: Record<string, any>;
  columns: Column[];
  entity: EntityConfig;
}

const { record, columns, entity } = Astro.props;
const rowId = `${entity.idPrefix}-${record.id}`;

function getDeleteConfirm(): string {
  if (!entity.deleteConfirmTemplate) return "削除しますか？";
  const name = entity.displayNameKey
    ? (record[entity.displayNameKey] ?? "")
    : "";
  return entity.deleteConfirmTemplate.replace("{name}", name);
}

/* ── 行内アクションスタイル ── */
const actionsCell = css({
  py: "4",
  px: "6",
  textAlign: "right",
});

const actionsRow = css({
  display: "flex",
  alignItems: "center",
  justifyContent: "flex-end",
  gap: "2",
});

const editBtn = css({
  display: "inline-flex",
  alignItems: "center",
  gap: "1",
  color: "#00288e",
  fontSize: "xs",
  fontWeight: "bold",
  px: "2",
  py: "1",
  rounded: "md",
  cursor: "pointer",
  border: "none",
  bg: "transparent",
  _hover: { bg: "rgba(0, 40, 142, 0.1)" },
});

const kebabBtn = css({
  display: "inline-flex",
  alignItems: "center",
  justifyContent: "center",
  w: "7",
  h: "7",
  rounded: "full",
  cursor: "pointer",
  color: "#757684",
  border: "none",
  bg: "transparent",
  _hover: { color: "#121c2a", bg: "#eff3ff" },
});

const kebabMenu = css({
  position: "absolute",
  right: "0",
  top: "100%",
  zIndex: 20,
  mt: "1",
  bg: "white",
  rounded: "lg",
  boxShadow: "0 10px 30px -5px rgba(18, 28, 42, 0.08)",
  py: "1",
  minW: "120px",
});

const kebabItem = css({
  display: "flex",
  alignItems: "center",
  gap: "2",
  w: "full",
  textAlign: "left",
  px: "3",
  py: "2",
  fontSize: "sm",
  cursor: "pointer",
  color: "#ba1a1a",
  border: "none",
  bg: "transparent",
  _hover: { bg: "rgba(255, 218, 214, 0.3)" },
});
const checkboxCell = css({
  py: "4",
  px: "6",
});

const checkboxStyle = css({
  rounded: "sm",
  cursor: "pointer",
  accentColor: "#00288e",
});
---

<tr id={rowId} class={row}>
  <td class={checkboxCell}>
    <input
      type="checkbox"
      name="rowSelect"
      value={record.id}
      class={checkboxStyle}
    />
  </td>
  {
    columns.map((col) => {
      const type = col.type ?? "text";
      const val = record[col.key];

      if (type === "actions") {
        return (
          <td class={actionsCell}>
            <div class={actionsRow}>
              <button
                hx-get={`${entity.baseUrl}/${record.id}/edit`}
                hx-target={`#${rowId}`}
                hx-swap="outerHTML"
                class={editBtn}
              >
                <Icon
                  name="heroicons:pencil-square"
                  class={css({ w: "3.5", h: "3.5" })}
                />
                編集
              </button>
              <div
                class={css({ position: "relative" })}
                x-data="{ menuOpen: false }"
                @click.outside="menuOpen = false"
              >
                <button
                  class={kebabBtn}
                  @click="menuOpen = !menuOpen"
                  type="button"
                >
                  <Icon
                    name="heroicons:ellipsis-vertical-solid"
                    class={css({ w: "5", h: "5" })}
                  />
                </button>
                <div class={kebabMenu} x-show="menuOpen" x-transition x-cloak>
                  <button
                    class={kebabItem}
                    hx-delete={`${entity.baseUrl}/${record.id}`}
                    hx-target={`#${rowId}`}
                    hx-swap="outerHTML swap:0.3s"
                    hx-confirm={getDeleteConfirm()}
                    @click="menuOpen = false"
                  >
                    <Icon
                      name="heroicons:trash"
                      class={css({ w: "4", h: "4" })}
                    />
                    削除
                  </button>
                </div>
              </div>
            </div>
          </td>
        );
      }

      if (type === "barcode") {
        return (
          <td class={tdCell}>{val ? <react-barcode value={val} /> : ""}</td>
        );
      }

      if (type === "number" || type === "computed") {
        const formatted =
          (col as any).format && val != null
            ? Number(val).toLocaleString()
            : (val ?? "");
        return <td class={tdCell}>{formatted}</td>;
      }

      // text, date, itemCode, readonlyLookup
      return <td class={tdCell}>{val ?? ""}</td>;
    })
  }
</tr>
