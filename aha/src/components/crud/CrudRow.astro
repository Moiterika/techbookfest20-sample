---
import type { Column, EntityConfig } from "./types";
import { tdCell, row } from "../../styles/common";
import { Icon } from "astro-icon/components";

interface Props {
  record: Record<string, any>;
  columns: Column[];
  entity: EntityConfig;
}

const { record, columns, entity } = Astro.props;
const rowId = `${entity.idPrefix}-${record.ID}`;

/** カラムの minWidth を反映した td クラスを返す */
function cellCls(col: { minWidth?: string }): string {
  return tdCell;
}

/** minWidth が指定されている場合の style 属性 */
function cellStyle(col: { minWidth?: string }): string | undefined {
  return col.minWidth ? `min-width:${col.minWidth}` : undefined;
}

function getDeleteConfirm(): string {
  if (!entity.deleteConfirmTemplate) return "削除しますか？";
  const name = entity.displayNameKey
    ? (record[entity.displayNameKey] ?? "")
    : "";
  return entity.deleteConfirmTemplate.replace("{name}", name);
}

/* ── 行内アクションスタイル ── */
const actionsCell = "py-4 px-6 text-right";
const actionsRow = "flex items-center justify-end gap-2";
const editBtn =
  "inline-flex items-center gap-1 text-primary text-xs font-bold px-2 py-1 rounded-md cursor-pointer border-none bg-transparent hover:bg-primary/10";
const kebabBtn =
  "inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-outline border-none bg-transparent hover:text-on-surface hover:bg-surface-container-low";
const kebabMenu =
  "absolute right-0 top-full z-20 mt-1 bg-white rounded-lg shadow-[0_10px_30px_-5px_rgba(18,28,42,0.08)] py-1 min-w-[120px]";
const kebabItem =
  "flex items-center gap-2 w-full text-left px-3 py-2 text-sm cursor-pointer text-error border-none bg-transparent hover:bg-error-container/30";
const checkboxCell = "py-4 px-6";
const checkboxStyle = "rounded-sm cursor-pointer accent-primary";
---

<tr id={rowId} class={row}>
  <td class={checkboxCell}>
    <input
      type="checkbox"
      name="rowSelect"
      value={record.ID}
      class={checkboxStyle}
    />
  </td>
  {
    columns.map((col) => {
      const type = col.type ?? "text";
      const val = record[col.key];

      if (type === "actions") {
        return (
          <td class={actionsCell}>
            <div class={actionsRow}>
              <button
                hx-get={`${entity.baseUrl}/${record.ID}/edit`}
                hx-target={`#${rowId}`}
                hx-swap="outerHTML"
                class={editBtn}
              >
                <Icon name="heroicons:pencil-square" class="w-3.5 h-3.5" />
                編集
              </button>
              <div
                class="relative"
                x-data="{ menuOpen: false }"
                @click.outside="menuOpen = false"
              >
                <button
                  class={kebabBtn}
                  @click="menuOpen = !menuOpen"
                  type="button"
                >
                  <Icon
                    name="heroicons:ellipsis-vertical-solid"
                    class="w-5 h-5"
                  />
                </button>
                <div class={kebabMenu} x-show="menuOpen" x-transition x-cloak>
                  <button
                    class={kebabItem}
                    hx-delete={`${entity.baseUrl}/${record.ID}`}
                    hx-target={`#${rowId}`}
                    hx-swap="outerHTML swap:0.3s"
                    hx-confirm={getDeleteConfirm()}
                    @click="menuOpen = false"
                  >
                    <Icon name="heroicons:trash" class="w-4 h-4" />
                    削除
                  </button>
                </div>
              </div>
            </div>
          </td>
        );
      }

      if (type === "barcode") {
        return (
          <td class={cellCls(col)} style={cellStyle(col)}>
            {val ? <react-barcode value={val} /> : ""}
          </td>
        );
      }

      if (type === "number" || type === "computed") {
        const formatted =
          (col as any).format && val != null
            ? Number(val).toLocaleString()
            : (val ?? "");
        return (
          <td class={cellCls(col)} style={cellStyle(col)}>
            {formatted}
          </td>
        );
      }

      if (type === "select") {
        const selCol = col as any;
        const opt = selCol.options.find(
          (o: any) => String(o.value) === String(val),
        );
        return (
          <td class={cellCls(col)} style={cellStyle(col)}>
            {opt ? opt.label : (val ?? "")}
          </td>
        );
      }

      // text, date, itemCode, typeahead, readonlyLookup
      return (
        <td class={cellCls(col)} style={cellStyle(col)}>
          {val ?? ""}
        </td>
      );
    })
  }
</tr>
