---
import { thCell } from "../../styles/common";
import type { Column } from "./types";

interface Props {
  /** カラム定義 */
  columns: Column[];
  /** tbody の id（htmx target） */
  bodyId: string;
  /** API ベース URL */
  baseUrl: string;
  /** ページネーション表示先の id */
  paginationId: string;
  /** テーブル要素の id（コピー/ダウンロード用） */
  tableId?: string;
}

const { columns, bodyId, baseUrl, paginationId, tableId } = Astro.props;

const tableWrapper =
  "overflow-x-auto rounded-xl bg-white [-webkit-overflow-scrolling:touch]";
const theadStyle = "bg-surface-container";
const checkboxTh = "py-4 px-6 w-10";
const checkboxStyle = "rounded-sm cursor-pointer accent-primary";

/** カラムごとの th スタイルを事前計算（width/minWidth は style 属性で） */
function thStyle(col: Column): string | undefined {
  const parts: string[] = [];
  if (col.width) parts.push(`width:${col.width}`);
  if (col.minWidth) parts.push(`min-width:${col.minWidth}`);
  return parts.length > 0 ? parts.join(";") : undefined;
}
---

<div class={tableWrapper}>
  <table id={tableId} class="w-full min-w-200 border-collapse text-left">
    <thead class={theadStyle}>
      <tr>
        <th class={checkboxTh}>
          <input
            type="checkbox"
            class={`crud-select-all ${checkboxStyle}`}
            data-body-id={bodyId}
          />
        </th>
        {
          columns.map((col) => (
            <th class={thCell} style={thStyle(col)}>
              {col.label}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody id={bodyId} hx-get={baseUrl} hx-trigger="load" hx-swap="innerHTML">
    </tbody>
  </table>
</div>
<div id={paginationId}></div>

<script>
  // ── select-all チェックボックス制御 ──
  document.addEventListener("change", (e) => {
    const target = e.target as HTMLInputElement;
    if (!target.classList.contains("crud-select-all")) return;

    const bodyId = target.dataset.bodyId;
    if (!bodyId) return;
    const tbody = document.getElementById(bodyId);
    if (!tbody) return;

    const boxes = tbody.querySelectorAll<HTMLInputElement>(
      'input[name="rowSelect"]',
    );
    boxes.forEach((cb) => (cb.checked = target.checked));
  });

  // htmx swap 後に select-all を解除
  document.addEventListener("htmx:afterSwap", (e) => {
    const target = e.target as HTMLElement;
    const table = target.closest("table");
    if (!table) return;
    const selectAll = table.querySelector<HTMLInputElement>(".crud-select-all");
    if (selectAll) selectAll.checked = false;
  });
</script>
