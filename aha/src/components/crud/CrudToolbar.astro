---
import { button } from "../../styles/common";
import { Icon } from "astro-icon/components";

interface Props {
  /** htmx リクエスト先の API ベース URL（例: "/api/items"） */
  baseUrl: string;
  /** tbody の id（htmx target） */
  bodyTargetId: string;
  /** テーブル要素の id（コピー/ダウンロード用） */
  tableId?: string;
  /** 検索コンテナの id（エクスポート時に中の input の値をクエリに含める） */
  searchContainerId?: string;
}

const { baseUrl, bodyTargetId, tableId, searchContainerId } = Astro.props;

/* ── レイアウト ── */
const toolbarRow = "flex justify-between items-center mb-6 flex-wrap gap-4";
const leftGroup = "flex items-center gap-3 flex-wrap";

/* ── ゴーストボタン（左側の操作系） ── */
const ghostBtn =
  "inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-150 text-primary bg-transparent border-none hover:bg-surface-container-high disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-transparent";
const ghostBtnDanger =
  "inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-150 text-error bg-error-container/20 border-none hover:bg-error-container/40 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-error-container/20";

/* ── ドロップダウン ── */
const dropdownWrapper = "relative";
const dropdownMenu =
  "absolute z-10 mt-1 bg-white rounded-lg shadow-[0_10px_30px_-5px_rgba(18,28,42,0.08)] py-1 min-w-[120px]";
const dropdownItem =
  "block w-full text-left px-3 py-1.5 text-sm cursor-pointer border-none bg-transparent hover:bg-surface-container-low";

/* ── アイコン ── */
const iconSm = "w-4.5 h-4.5";
---

<div
  class={toolbarRow}
  x-data={`{ hasSelection: false, updateSelection() { const tbody = document.getElementById('${bodyTargetId}'); this.hasSelection = tbody ? tbody.querySelectorAll('input[name=\\"rowSelect\\"]:checked').length > 0 : false; } }`}
  @change.window="updateSelection()"
  @htmx--after-swap.window="$nextTick(() => updateSelection())"
>
  {/* ── 左: 操作ボタン群 ── */}
  <div class={leftGroup}>
    {/* 選択コピー */}
    <button
      class={ghostBtn}
      data-bulk-copy
      data-body-target={bodyTargetId}
      :disabled="!hasSelection"
    >
      <Icon name="heroicons:clipboard-document" class={iconSm} />
      選択コピー
    </button>

    {/* 選択削除 */}
    <button
      class={ghostBtnDanger}
      data-bulk-delete={baseUrl}
      data-body-target={bodyTargetId}
      :disabled="!hasSelection"
    >
      <Icon name="heroicons:trash" class={iconSm} />
      選択削除
    </button>
  </div>

  {/* ── 右: ダウンロード・更新・新規追加 ── */}
  <div class={leftGroup}>
    {
      tableId && (
        <div
          class={dropdownWrapper}
          x-data="{ dlOpen: false }"
          @click.outside="dlOpen = false"
        >
          <button class={ghostBtn} @click="dlOpen = !dlOpen">
            <Icon name="heroicons:arrow-down-tray" class={iconSm} />
            ダウンロード
          </button>
          <div class={dropdownMenu} x-show="dlOpen" x-transition x-cloak>
            <button
              class={dropdownItem}
              @click={`window.__crudExport('${baseUrl}', 'csv', '${searchContainerId ?? ""}'); dlOpen = false`}
            >
              CSV
            </button>
            <button
              class={dropdownItem}
              @click={`window.__crudExport('${baseUrl}', 'tsv', '${searchContainerId ?? ""}'); dlOpen = false`}
            >
              TSV
            </button>
            <button
              class={dropdownItem}
              @click={`window.__crudExport('${baseUrl}', 'xlsx', '${searchContainerId ?? ""}'); dlOpen = false`}
            >
              Excel (xlsx)
            </button>
          </div>
        </div>
      )
    }

    <button
      class={ghostBtn}
      hx-get={baseUrl}
      hx-target={`#${bodyTargetId}`}
      hx-swap="innerHTML"
    >
      <Icon name="heroicons:arrow-path" class={iconSm} />
      更新
    </button>

    <button
      @click="open = !open"
      x-text="open ? '閉じる' : '＋ 新規追加'"
      class:list={["btn", button({ intent: "primary" })]}></button>
  </div>
</div>

<script>
  /**
   * サーバーサイドエクスポート — 検索条件に合致する全件をダウンロード
   */
  function exportFromServer(
    baseUrl: string,
    format: string,
    searchContainerId: string,
  ) {
    const params = new URLSearchParams({ format });
    if (searchContainerId) {
      const container = document.getElementById(searchContainerId);
      if (container) {
        container
          .querySelectorAll<HTMLInputElement>("input[name], select[name]")
          .forEach((el) => {
            if (el.value) params.set(el.name, el.value);
          });
      }
    }
    window.location.href = `${baseUrl}/export?${params}`;
  }

  (window as any).__crudExport = exportFromServer;

  /**
   * 選択コピー — チェック済み行のテキストを TSV でクリップボードにコピー
   */
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>(
      "[data-bulk-copy]",
    );
    if (!btn) return;

    const bodyTargetId = btn.dataset.bodyTarget!;
    const tbody = document.getElementById(bodyTargetId);
    if (!tbody) return;

    const table = tbody.closest("table") as HTMLTableElement | null;
    if (!table) return;

    // 操作列のインデックスを特定（除外用）
    const thCells = Array.from(table.querySelectorAll("thead th"));
    const actionIdx = thCells.findIndex(
      (th) => th.textContent?.trim() === "操作",
    );
    // チェックボックス列（先頭）も除外
    const skipIndices = new Set([0]);
    if (actionIdx >= 0) skipIndices.add(actionIdx);

    const headers = thCells
      .filter((_, i) => !skipIndices.has(i))
      .map((th) => th.textContent?.trim() ?? "");

    const checked = Array.from(
      tbody.querySelectorAll<HTMLInputElement>(
        'input[name="rowSelect"]:checked',
      ),
    );
    if (checked.length === 0) return;

    if (!confirm(`${checked.length} 件の行をクリップボードにコピーしますか？`))
      return;

    const rows = checked.map((cb) => {
      const tr = cb.closest("tr")!;
      const cells = Array.from(tr.querySelectorAll("td"));
      return cells
        .filter((_, i) => !skipIndices.has(i))
        .map((td) => td.textContent?.trim() ?? "");
    });

    const tsv = [headers, ...rows].map((r) => r.join("\t")).join("\n");
    navigator.clipboard.writeText(tsv);
  });

  /**
   * 選択削除 — チェック済み行の ID を収集して DELETE を送信
   */
  document.addEventListener("click", async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>(
      "[data-bulk-delete]",
    );
    if (!btn) return;

    const baseUrl = btn.dataset.bulkDelete!;
    const bodyTargetId = btn.dataset.bodyTarget!;
    const tbody = document.getElementById(bodyTargetId);
    if (!tbody) return;

    const checked = Array.from(
      tbody.querySelectorAll<HTMLInputElement>(
        'input[name="rowSelect"]:checked',
      ),
    );
    if (checked.length === 0) {
      alert("削除する項目を選択してください");
      return;
    }

    const ids = checked.map((cb) => cb.value);
    if (!confirm(`${ids.length} 件の項目を削除しますか？`)) return;

    const res = await fetch(baseUrl, {
      method: "DELETE",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ids }),
    });
    if (res.ok) {
      // 行をテーブルから削除
      checked.forEach((cb) => {
        const tr = cb.closest("tr");
        if (tr) tr.remove();
      });
      // select-all チェックを解除
      const table = tbody.closest("table");
      const selectAll =
        table?.querySelector<HTMLInputElement>(".crud-select-all");
      if (selectAll) selectAll.checked = false;
    }
  });
</script>
