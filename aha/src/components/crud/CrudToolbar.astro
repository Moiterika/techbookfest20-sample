---
import { css } from "../../../styled-system/css";
import { btnPrimary, btnSecondary } from "../../styles/common.css";

interface Props {
  /** htmx リクエスト先の API ベース URL（例: "/api/items"） */
  baseUrl: string;
  /** tbody の id（htmx target） */
  bodyTargetId: string;
  /** テーブル要素の id（コピー/ダウンロード用） */
  tableId?: string;
  /** 検索コンテナの id（エクスポート時に中の input の値をクエリに含める） */
  searchContainerId?: string;
}

const { baseUrl, bodyTargetId, tableId, searchContainerId } = Astro.props;

const toolbarRow = css({
  display: "flex",
  gap: "3",
  mb: "6",
  flexWrap: "wrap",
  alignItems: "center",
});

const dropdownWrapper = css({
  position: "relative",
});

const dropdownMenu = css({
  position: "absolute",
  zIndex: 10,
  mt: "1",
  bg: "white",
  border: "1px solid",
  borderColor: "slate.200",
  rounded: "md",
  boxShadow: "lg",
  py: "1",
  minW: "120px",
});

const dropdownItem = css({
  display: "block",
  w: "full",
  textAlign: "left",
  px: "3",
  py: "1.5",
  fontSize: "sm",
  cursor: "pointer",
  _hover: { bg: "slate.50" },
});

const copyOk = css({
  fontSize: "xs",
  color: "emerald.600",
  fontWeight: "medium",
});
---

<div class={toolbarRow}>
  <button
    @click="open = !open"
    x-text="open ? '閉じる' : '＋ 新規追加'"
    class:list={["btn", btnPrimary]}></button>

  <button
    hx-get={baseUrl}
    hx-target={`#${bodyTargetId}`}
    hx-swap="innerHTML"
    class:list={["btn", btnSecondary]}
  >
    <svg
      class={css({ w: "4", h: "4", mr: "1.5" })}
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"
      ></path>
    </svg>
    更新
  </button>

  {
    tableId && (
      <>
        {/* TSV コピーボタン */}
        <div x-data="{ copied: false }">
          <button
            class:list={["btn", btnSecondary]}
            @click={`
              const data = window.__crudTableData('${tableId}');
              if (!data) return;
              const tsv = data.map(r => r.join('\\t')).join('\\n');
              navigator.clipboard.writeText(tsv).then(() => {
                copied = true; setTimeout(() => copied = false, 2000);
              });
            `}
          >
            <svg
              class={css({ w: "4", h: "4", mr: "1.5" })}
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"
              />
            </svg>
            <span x-show="!copied">コピー</span>
            <span x-show="copied" class={copyOk} x-cloak>
              コピー済み
            </span>
          </button>
        </div>

        {/* ダウンロードボタン（サーバーサイド全件エクスポート） */}
        <div
          class={dropdownWrapper}
          x-data="{ dlOpen: false }"
          @click.outside="dlOpen = false"
        >
          <button class:list={["btn", btnSecondary]} @click="dlOpen = !dlOpen">
            <svg
              class={css({ w: "4", h: "4", mr: "1.5" })}
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
              />
            </svg>
            ダウンロード
          </button>
          <div class={dropdownMenu} x-show="dlOpen" x-transition x-cloak>
            <button
              class={dropdownItem}
              @click={`window.__crudExport('${baseUrl}', 'csv', '${searchContainerId ?? ""}'); dlOpen = false`}
            >
              CSV
            </button>
            <button
              class={dropdownItem}
              @click={`window.__crudExport('${baseUrl}', 'tsv', '${searchContainerId ?? ""}'); dlOpen = false`}
            >
              TSV
            </button>
            <button
              class={dropdownItem}
              @click={`window.__crudExport('${baseUrl}', 'xlsx', '${searchContainerId ?? ""}'); dlOpen = false`}
            >
              Excel (xlsx)
            </button>
          </div>
        </div>
      </>
    )
  }
</div>

<script>
  /**
   * テーブルからヘッダ+データ行を2次元配列で取得（操作列を除外）— TSVコピー用
   */
  function getTableData(tableId: string): string[][] | null {
    const table = document.getElementById(tableId) as HTMLTableElement | null;
    if (!table) return null;

    const thCells = Array.from(table.querySelectorAll("thead th"));
    const actionIdx = thCells.findIndex(
      (th) => th.textContent?.trim() === "操作",
    );
    const headers = thCells
      .filter((_, i) => actionIdx < 0 || i !== actionIdx)
      .map((th) => th.textContent?.trim() ?? "");

    const rows = Array.from(table.querySelectorAll("tbody tr"));
    const data = rows.map((tr) => {
      const cells = Array.from(tr.querySelectorAll("td"));
      return cells
        .filter((_, i) => actionIdx < 0 || i !== actionIdx)
        .map((td) => td.textContent?.trim() ?? "");
    });

    return [headers, ...data];
  }

  /**
   * サーバーサイドエクスポート — 検索条件に合致する全件をダウンロード
   */
  function exportFromServer(
    baseUrl: string,
    format: string,
    searchContainerId: string,
  ) {
    const params = new URLSearchParams({ format });
    // 検索コンテナ内の全 input の値をクエリに含める
    if (searchContainerId) {
      const container = document.getElementById(searchContainerId);
      if (container) {
        container
          .querySelectorAll<HTMLInputElement>("input[name], select[name]")
          .forEach((el) => {
            if (el.value) params.set(el.name, el.value);
          });
      }
    }
    // ブラウザにダウンロードさせる
    window.location.href = `${baseUrl}/export?${params}`;
  }

  // グローバル公開
  (window as any).__crudTableData = getTableData;
  (window as any).__crudExport = exportFromServer;
</script>
