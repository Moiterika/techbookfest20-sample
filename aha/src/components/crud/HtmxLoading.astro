<!-- Alpine.js: htmx リクエスト中のローディング表示 -->
<div
  x-data="{ loading: false }"
  @htmx:before-request.window="loading = true"
  @htmx:after-request.window="loading = false"
>
  <div
    x-show="loading"
    x-transition.opacity
    class="fixed bottom-4 right-4 bg-gradient-to-br from-primary to-primary-dark text-white px-4 py-2 rounded-lg text-sm shadow-[0_10px_30px_-5px_rgba(18,28,42,0.08)]"
  >
    読み込み中…
  </div>
</div>
