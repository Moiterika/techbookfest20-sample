---
import { css } from "../../../styled-system/css";
---

<!-- Alpine.js: htmx リクエスト中のローディング表示 -->
<div
  x-data="{ loading: false }"
  @htmx:before-request.window="loading = true"
  @htmx:after-request.window="loading = false"
>
  <div
    x-show="loading"
    x-transition.opacity
    class={css({
      position: "fixed",
      bottom: "4",
      right: "4",
      bg: "black",
      color: "white",
      px: "4",
      py: "2",
      rounded: "lg",
      opacity: "0.8",
      fontSize: "sm",
    })}
  >
    読み込み中…
  </div>
</div>
