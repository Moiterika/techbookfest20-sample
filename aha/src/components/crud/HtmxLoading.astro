---
import { css } from "../../../styled-system/css";
---

<!-- Alpine.js: htmx リクエスト中のローディング表示 -->
<div
  x-data="{ loading: false }"
  @htmx:before-request.window="loading = true"
  @htmx:after-request.window="loading = false"
>
  <div
    x-show="loading"
    x-transition.opacity
    class={css({
      position: "fixed",
      bottom: "4",
      right: "4",
      background: "linear-gradient(135deg, #00288e, #1e40af)",
      color: "white",
      px: "4",
      py: "2",
      rounded: "lg",
      fontSize: "sm",
      boxShadow: "0 10px 30px -5px rgba(18, 28, 42, 0.08)",
    })}
  >
    読み込み中…
  </div>
</div>
