---
import type { TypeaheadConfig } from "./types";
import TypeaheadSearch from "./TypeaheadSearch.astro";
import TypeaheadBadge from "./TypeaheadBadge.astro";

interface Props {
  config: TypeaheadConfig;
  name?: string;
  selectedId?: number;
  selectedCode?: string;
  selectedName?: string;
  selectedExtra?: Record<string, string>;
  formId?: string;
  compact?: boolean;
  hideNameLabel?: boolean;
  lookupTargetId?: string;
}

const {
  config,
  name = "itemId",
  selectedId,
  selectedCode = "",
  selectedName = "",
  selectedExtra = {},
  formId,
  compact = false,
  hideNameLabel = false,
  lookupTargetId,
} = Astro.props;

const typeaheadUrl = `/api/${config.entityName}/typeahead?action=clear`;

const hxVals = JSON.stringify({
  taName: name,
  taFormId: formId ?? "",
  taCompact: String(compact),
  taHideNameLabel: String(hideNameLabel),
  taLookupId: lookupTargetId ?? "",
  taEntity: config.entityName,
});

// extraDataKeys からイベント detail を構築する after-swap ハンドラ
const extraParts = (config.extraDataKeys ?? [])
  .map(
    (k) =>
      `${k}: Number(el.dataset.selected${k.charAt(0).toUpperCase() + k.slice(1)} || 0)`,
  )
  .join(", ");
const detailObj = extraParts
  ? `{ name: el.dataset.selectedName, ${extraParts} }`
  : "{ name: el.dataset.selectedName }";

const afterSwapHandler = [
  "const el = this.querySelector('[data-selected-name]');",
  "if (el) {",
  `  const d = ${detailObj};`,
  "  this.dispatchEvent(new CustomEvent('item-selected', { detail: d, bubbles: true }));",
  "}",
].join(" ");
---

<div
  data-typeahead
  class="relative"
  hx-vals={hxVals}
  hx-target="this"
  hx-get={typeaheadUrl}
  hx-trigger="typeahead-reset from:body"
  hx-swap="innerHTML"
  hx-disinherit="hx-target"
  hx-on--after-swap={afterSwapHandler}
>
  {
    selectedId ? (
      <TypeaheadBadge
        config={config}
        name={name}
        selectedId={selectedId}
        selectedCode={selectedCode}
        selectedName={selectedName}
        selectedExtra={selectedExtra}
        formId={formId}
        hideNameLabel={hideNameLabel}
      />
    ) : (
      <TypeaheadSearch
        config={config}
        name={name}
        formId={formId}
        compact={compact}
      />
    )
  }
</div>
