---
import type { TypeaheadConfig } from "./types";
import { selectedRow, badge, badgeClear, nameLabel } from "./typeaheadStyles";

interface Props {
  config: TypeaheadConfig;
  name?: string;
  selectedId: number;
  selectedCode: string;
  selectedName: string;
  selectedExtra?: Record<string, string>;
  formId?: string;
  hideNameLabel?: boolean;
}

const {
  config,
  name = "itemId",
  selectedId,
  selectedCode,
  selectedName,
  selectedExtra = {},
  formId,
  hideNameLabel = false,
} = Astro.props;

const typeaheadUrl = `/api/${config.entityName}/typeahead?action=clear`;

// data-selected-* 属性を構築
const dataAttrs: Record<string, string> = {
  "data-selected-name": selectedName,
};
for (const [key, val] of Object.entries(selectedExtra)) {
  dataAttrs[`data-selected-${key}`] = val;
}
---

<div class={selectedRow} {...dataAttrs}>
  <span class={badge}>
    {selectedCode}
    <button
      type="button"
      class={badgeClear}
      hx-get={typeaheadUrl}
      hx-target="closest [data-typeahead]"
      hx-swap="innerHTML">&times;</button
    >
  </span>
  {!hideNameLabel && <span class={nameLabel}>{selectedName}</span>}
</div>
<input
  type="hidden"
  name={name}
  value={String(selectedId)}
  {...formId ? { form: formId } : {}}
/>
