---
import type { TypeaheadConfig } from "./types";
import { inputStyle, inputStyleSm } from "../../styles/common";
import { dropdown } from "./typeaheadStyles";

interface Props {
  config: TypeaheadConfig;
  name?: string;
  formId?: string;
  compact?: boolean;
}

const { config, name = "品目ID", formId, compact = false } = Astro.props;
const searchUrl = `/api/${config.entityName}/search`;
---

<div x-data="{ open: false }" class="relative">
  <input
    type="text"
    placeholder={config.placeholder ?? "検索…"}
    class={compact ? inputStyleSm : inputStyle}
    autocomplete="off"
    hx-get={searchUrl}
    hx-trigger="input changed delay:300ms"
    hx-target="next ul"
    hx-swap="innerHTML"
    hx-include="this"
    name="q"
    @focus="open = true"
    @input="open = true"
    @click.outside="open = false"
    @keydown.escape="open = false"
  />
  <ul class={dropdown} x-show="open" x-transition></ul>
</div>
<input type="hidden" name={name} value="" {...formId ? { form: formId } : {}} />
