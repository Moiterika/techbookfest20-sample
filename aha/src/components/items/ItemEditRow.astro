---
import type { Item } from "../../db/schema";
import {
  btnSecondary,
  btnPrimary,
  tdCell,
  inputStyleSm,
  row,
  flexRow,
} from "../../styles/common.css";

interface Props {
  item: Item;
}

const { item } = Astro.props;
---

<tr id={`item-${item.id}`} class={row}>
  <td class={tdCell}
    ><input
      name="name"
      value={item.name}
      form={`edit-${item.id}`}
      required
      class={inputStyleSm}
    /></td
  >
  <td class={tdCell}
    ><input
      name="category"
      value={item.category ?? ""}
      form={`edit-${item.id}`}
      class={inputStyleSm}
    /></td
  >
  <td class={tdCell}
    ><input
      name="price"
      type="number"
      value={item.price}
      form={`edit-${item.id}`}
      class={inputStyleSm}
    /></td
  >
  <td class={tdCell}>
    <div class={flexRow}>
      <form
        id={`edit-${item.id}`}
        hx-put={`/api/items/${item.id}`}
        hx-target={`#item-${item.id}`}
        hx-swap="outerHTML"
      >
        <button type="submit" class={btnPrimary}>保存</button>
      </form>
      <button
        hx-get="/api/items"
        hx-target="#items-body"
        hx-swap="innerHTML"
        class={btnSecondary}>キャンセル</button
      >
    </div>
  </td>
</tr>
