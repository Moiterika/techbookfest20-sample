---
import { css } from "../../../styled-system/css";
import {
  btnPrimary,
  inputStyle,
  labelStyle,
  card,
  cardTitle,
} from "../../styles/common.css";
---

<!-- Alpine.js: x-show + x-transition でスライド表示 -->
<div x-show="open" x-transition class={card}>
  <h2 class={cardTitle}>新規品目登録</h2>
  <form
    hx-post="/api/items"
    hx-target="#items-body"
    hx-swap="innerHTML"
    hx-on--after-request="if(event.detail.successful) this.reset()"
    class={css({ display: "flex", flexDirection: "column", gap: "4" })}
  >
    <label class={labelStyle}>
      <span>品目名 <span class={css({ color: "rose.500" })}>*</span></span>
      <input name="name" required class={inputStyle} placeholder="例: ノートPC" />
    </label>
    <label class={labelStyle}>
      カテゴリ
      <input name="category" class={inputStyle} placeholder="例: 備品" />
    </label>
    <label class={labelStyle}>
      単価 (円)
      <input name="price" type="number" value="0" min="0" class={inputStyle} />
    </label>
    <div class={css({ mt: "2" })}>
      <button
        type="submit"
        class:list={["btn", btnPrimary]}
      >
        登録する
      </button>
    </div>
  </form>
</div>
