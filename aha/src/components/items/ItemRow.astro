---
import type { Item } from "../../db/schema";
import { btnSm, btnDanger, tdCell, row } from "./styles.css";

interface Props {
  item: Item;
}

const { item } = Astro.props;
---

<tr id={`item-${item.id}`} class={row}>
  <td class={tdCell}>{item.name}</td>
  <td class={tdCell}>{item.category ?? ""}</td>
  <td class={tdCell}>{item.price.toLocaleString()}</td>
  <td class={tdCell}>
    <button
      hx-get={`/api/items/${item.id}/edit`}
      hx-target={`#item-${item.id}`}
      hx-swap="outerHTML"
      class={btnSm}>編集</button>
    <button
      hx-delete={`/api/items/${item.id}`}
      hx-target={`#item-${item.id}`}
      hx-swap="outerHTML swap:0.3s"
      hx-confirm={`「${item.name}」を削除しますか？`}
      class={btnDanger}>削除</button>
  </td>
</tr>
