---
import { css } from "../../../styled-system/css";
import { thCell } from "../../styles/common.css";

const tableWrapper = css({
  overflowX: "auto",
  rounded: "xl",
  border: "1px solid",
  borderColor: "slate.200",
  bg: "white",
  boxShadow: "sm",
});
---

<div class={tableWrapper}>
  <table
    class={css({ w: "full", borderCollapse: "collapse", textAlign: "left" })}
  >
    <thead
      class={css({
        bg: "slate.50",
        borderBottom: "1px solid",
        borderColor: "slate.200",
      })}
    >
      <tr>
        <th class={thCell}>品目名</th>
        <th class={thCell}>カテゴリ</th>
        <th class={thCell}>単価</th>
        <th class={`${thCell} ${css({ w: "32" })}`}>操作</th>
      </tr>
    </thead>
    <tbody
      id="items-body"
      hx-get="/api/items"
      hx-trigger="load"
      hx-swap="innerHTML"
      class={css({ divideY: "1px", borderColor: "slate.200" })}
    >
    </tbody>
  </table>
</div>
