---
import { css } from "../../../styled-system/css";
import { inputStyle, inputStyleSm } from "../../styles/common.css";

interface Props {
  /** hidden input の name 属性 */
  name?: string;
  /** 初期選択済み品目ID（編集時） */
  selectedId?: number;
  /** 初期選択済み品目コード（編集時） */
  selectedCode?: string;
  /** 初期選択済み品目名（編集時） */
  selectedName?: string;
  /** form 属性（EditRow から使う場合） */
  formId?: string;
  /** コンパクト表示（テーブル行内用） */
  compact?: boolean;
  /** 品目名ラベルを非表示にする（外部で名前列を別に表示する場合） */
  hideNameLabel?: boolean;
}

const {
  name = "itemId",
  selectedId,
  selectedCode = "",
  selectedName = "",
  formId,
  compact = false,
  hideNameLabel = false,
} = Astro.props;

const wrapper = css({ position: "relative" });

const dropdown = css({
  position: "absolute",
  zIndex: 10,
  w: "full",
  mt: "1",
  bg: "white",
  border: "1px solid",
  borderColor: "slate.200",
  rounded: "md",
  boxShadow: "lg",
  maxH: "200px",
  overflowY: "auto",
});

const selectedRow = css({
  display: "flex",
  alignItems: "center",
  gap: "2",
});

const nameLabel = css({
  fontSize: "sm",
  color: "slate.600",
  whiteSpace: "nowrap",
});

const clearBtn = css({
  fontSize: "xs",
  color: "slate.400",
  cursor: "pointer",
  px: "1.5",
  py: "0.5",
  rounded: "md",
  _hover: { color: "slate.600", bg: "slate.100" },
  flexShrink: 0,
});

const initData = JSON.stringify({
  q: selectedCode,
  selectedId: selectedId ?? null,
  selectedCode: selectedCode,
  selectedName: selectedName,
  open: false,
}).replace(/'/g, "\\'");
---

<div
  class={wrapper}
  x-data={initData}
  @typeahead-reset.window="selectedId = null; selectedCode = ''; selectedName = ''; q = ''"
>
  <div class={selectedRow}>
    {/* コード入力 / 検索 */}
    <div class={css({ position: "relative", flex: "1" })}>
      <input
        type="text"
        x-model="q"
        placeholder="品目コード or 名前で検索…"
        class={compact ? inputStyleSm : inputStyle}
        autocomplete="off"
        hx-get="/api/items/search"
        hx-trigger="input changed delay:300ms"
        hx-target="next ul"
        hx-swap="innerHTML"
        hx-include="this"
        name="q"
        x-bind:readonly="!!selectedId"
        @focus="if(!selectedId) open = true"
        @input="if(!selectedId) open = true"
        @click.outside="open = false"
        @keydown.escape="open = false"
      />
      <ul class={dropdown} x-show="open && !selectedId" x-transition></ul>
    </div>
    {/* 選択済み: 品目名 + クリアボタン */}
    {
      !hideNameLabel && (
        <template x-if="selectedId">
          <span class={nameLabel} x-text="selectedName" />
        </template>
      )
    }
    <template x-if="selectedId">
      <button
        type="button"
        class={clearBtn}
        @click="selectedId = null; selectedCode = ''; selectedName = ''; q = ''"
        >&times;</button
      >
    </template>
  </div>
  <input
    type="hidden"
    name={name}
    x-bind:value="selectedId"
    {...formId ? { form: formId } : {}}
  />
</div>
