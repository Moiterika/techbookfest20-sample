---
import { css } from "../../../styled-system/css";
import ItemTypeaheadSearch from "./ItemTypeaheadSearch.astro";
import ItemTypeaheadBadge from "./ItemTypeaheadBadge.astro";

interface Props {
  /** hidden input の name 属性 */
  name?: string;
  /** 初期選択済み品目ID（編集時） */
  selectedId?: number;
  /** 初期選択済み品目コード（編集時） */
  selectedCode?: string;
  /** 初期選択済み品目名（編集時） */
  selectedName?: string;
  /** 初期選択済み品目単価（編集時） */
  selectedPrice?: number;
  /** form 属性（EditRow から使う場合） */
  formId?: string;
  /** コンパクト表示（テーブル行内用） */
  compact?: boolean;
  /** 品目名ラベルを非表示にする（外部で名前列を別に表示する場合） */
  hideNameLabel?: boolean;
  /** OOB で品目名を更新する先の要素 ID */
  lookupTargetId?: string;
}

const {
  name = "itemId",
  selectedId,
  selectedCode = "",
  selectedName = "",
  selectedPrice,
  formId,
  compact = false,
  hideNameLabel = false,
  lookupTargetId,
} = Astro.props;

const hxVals = JSON.stringify({
  taName: name,
  taFormId: formId ?? "",
  taCompact: String(compact),
  taHideNameLabel: String(hideNameLabel),
  taLookupId: lookupTargetId ?? "",
});

const afterSwapHandler = [
  "const el = this.querySelector('[data-selected-name]');",
  "if (el) {",
  "  const d = { name: el.dataset.selectedName, price: Number(el.dataset.selectedPrice || 0) };",
  "  this.dispatchEvent(new CustomEvent('item-selected', { detail: d, bubbles: true }));",
  "}",
].join(" ");
---

<div
  data-typeahead
  class={css({ position: "relative" })}
  hx-vals={hxVals}
  hx-target="this"
  hx-get="/api/items/typeahead?action=clear"
  hx-trigger="typeahead-reset from:body"
  hx-swap="innerHTML"
  hx-disinherit="hx-target"
  hx-on--after-swap={afterSwapHandler}
>
  {
    selectedId ? (
      <ItemTypeaheadBadge
        name={name}
        selectedId={selectedId}
        selectedCode={selectedCode}
        selectedName={selectedName}
        selectedPrice={selectedPrice}
        formId={formId}
        hideNameLabel={hideNameLabel}
      />
    ) : (
      <ItemTypeaheadSearch name={name} formId={formId} compact={compact} />
    )
  }
</div>
