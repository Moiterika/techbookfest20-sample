---
import type { Transaction } from "../../db/schema";
import {
  btnSecondary,
  btnPrimary,
  tdCell,
  inputStyleSm,
  row,
  flexRow,
} from "../../styles/common.css";
import { css } from "../../../styled-system/css";
import ItemTypeahead from "../items/ItemTypeahead.astro";

interface Props {
  transaction: Transaction & { itemCode?: string; itemName?: string };
}

const { transaction: tx } = Astro.props;
---

<tr
  id={`tx-${tx.id}`}
  class={row}
  x-data={`{ unitPrice: ${tx.unitPrice}, quantity: ${tx.quantity} }`}
>
  <td class={tdCell}>
    <input
      name="date"
      type="date"
      value={tx.date}
      form={`edit-tx-${tx.id}`}
      required
      class={inputStyleSm}
    />
  </td>
  <td class={tdCell}>
    <ItemTypeahead
      name="itemId"
      selectedId={tx.itemId}
      selectedCode={tx.itemCode ?? ""}
      selectedName={tx.itemName ?? ""}
      formId={`edit-tx-${tx.id}`}
      compact
      hideNameLabel
    />
  </td>
  <td class={tdCell}>
    <span class={css({ fontSize: "sm", color: "slate.500" })}
      >{tx.itemName ?? ""}</span
    >
  </td>
  <td class={tdCell}>
    <input
      name="unitPrice"
      type="number"
      value={tx.unitPrice}
      form={`edit-tx-${tx.id}`}
      required
      min="0"
      class={inputStyleSm}
      x-model.number="unitPrice"
    />
  </td>
  <td class={tdCell}>
    <input
      name="quantity"
      type="number"
      value={tx.quantity}
      form={`edit-tx-${tx.id}`}
      required
      min="1"
      class={inputStyleSm}
      x-model.number="quantity"
    />
  </td>
  <td class={tdCell}>
    <span
      class={css({ fontWeight: "medium" })}
      x-text="(unitPrice * quantity).toLocaleString()"></span>
  </td>
  <td class={tdCell}>
    <div class={flexRow}>
      <form
        id={`edit-tx-${tx.id}`}
        hx-put={`/api/transactions/${tx.id}`}
        hx-target={`#tx-${tx.id}`}
        hx-swap="outerHTML"
        hx-on--before-request={`
          const itemId = document.querySelector('[form=edit-tx-${tx.id}][name=itemId]');
          if (!itemId || !itemId.value) {
            event.preventDefault();
            alert('品目を選択してください');
          }
        `}
      >
        <button type="submit" class={btnPrimary}>保存</button>
      </form>
      <button
        hx-get="/api/transactions"
        hx-target="#tx-body"
        hx-swap="innerHTML"
        class={btnSecondary}>キャンセル</button
      >
    </div>
  </td>
</tr>
