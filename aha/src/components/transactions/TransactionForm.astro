---
import { css } from "../../../styled-system/css";
import {
  btnPrimary,
  inputStyle,
  labelStyle,
  card,
  cardTitle,
} from "../../styles/common.css";
import ItemTypeahead from "../items/ItemTypeahead.astro";

const today = new Date().toISOString().slice(0, 10);
---

<div
  x-show="open"
  x-transition
  class={card}
  x-data="{ unitPrice: 0, quantity: 1 }"
  @item-selected="unitPrice = $event.detail.price"
>
  <h2 class={cardTitle}>新規取引登録</h2>
  <form
    hx-post="/api/transactions"
    hx-target="#tx-body"
    hx-swap="innerHTML"
    hx-on--before-request="if(event.detail.elt === this && !this.querySelector('[name=itemId]')?.value) { event.preventDefault(); alert('品目を選択してください'); }"
    @htmx:after-request="if($event.detail.successful && $event.detail.elt === $el) { $el.reset(); unitPrice = 0; quantity = 1; $dispatch('typeahead-reset'); open = false }"
    class={css({ display: "flex", flexDirection: "column", gap: "4" })}
  >
    <label class={labelStyle}>
      <span>日付 <span class={css({ color: "rose.500" })}>*</span></span>
      <input
        name="date"
        type="date"
        required
        value={today}
        class={inputStyle}
      />
    </label>
    <label class={labelStyle}>
      <span>品目 <span class={css({ color: "rose.500" })}>*</span></span>
      <ItemTypeahead />
    </label>
    <label class={labelStyle}>
      <span>単価 (円) <span class={css({ color: "rose.500" })}>*</span></span>
      <input
        name="unitPrice"
        type="number"
        required
        min="0"
        value="0"
        class={inputStyle}
        x-model.number="unitPrice"
      />
    </label>
    <label class={labelStyle}>
      <span>数量 <span class={css({ color: "rose.500" })}>*</span></span>
      <input
        name="quantity"
        type="number"
        required
        min="1"
        value="1"
        class={inputStyle}
        x-model.number="quantity"
      />
    </label>
    <div class={css({ fontSize: "sm", color: "slate.600" })}>
      金額: <strong x-text="(unitPrice * quantity).toLocaleString()"></strong> 円
    </div>
    <div class={css({ mt: "2" })}>
      <button type="submit" class:list={["btn", btnPrimary]}>登録する</button>
    </div>
  </form>
</div>
