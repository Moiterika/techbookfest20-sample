---
import type { Transaction } from "../../db/schema";
import {
  btnSecondary,
  btnDanger,
  tdCell,
  row,
  flexRow,
} from "../../styles/common.css";

interface Props {
  transaction: Transaction & { itemCode?: string; itemName?: string };
}

const { transaction: tx } = Astro.props;
---

<tr id={`tx-${tx.id}`} class={row}>
  <td class={tdCell}>{tx.date}</td>
  <td class={tdCell}>{tx.itemCode ?? ""}</td>
  <td class={tdCell}>{tx.itemName ?? ""}</td>
  <td class={tdCell}>{tx.unitPrice.toLocaleString()}</td>
  <td class={tdCell}>{tx.quantity.toLocaleString()}</td>
  <td class={tdCell}>{tx.amount.toLocaleString()}</td>
  <td class={tdCell}>
    <div class={flexRow}>
      <button
        hx-get={`/api/transactions/${tx.id}/edit`}
        hx-target={`#tx-${tx.id}`}
        hx-swap="outerHTML"
        class={btnSecondary}>編集</button
      >
      <button
        hx-delete={`/api/transactions/${tx.id}`}
        hx-target={`#tx-${tx.id}`}
        hx-swap="outerHTML swap:0.3s"
        hx-confirm="この取引を削除しますか？"
        class={btnDanger}>削除</button
      >
    </div>
  </td>
</tr>
