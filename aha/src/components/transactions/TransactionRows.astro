---
import type { Transaction } from "../../db/schema";
import { css } from "../../../styled-system/css";
import TransactionRow from "./TransactionRow.astro";
import CrudPagination from "../crud/CrudPagination.astro";

interface Props {
  transactions: (Transaction & { itemCode?: string; itemName?: string })[];
  currentPage?: number;
  totalPages?: number;
  pageSize?: number;
  extraParams?: Record<string, string>;
}

const {
  transactions,
  currentPage = 1,
  totalPages = 1,
  pageSize = 20,
  extraParams = {},
} = Astro.props;

const emptyCell = css({ textAlign: "center", py: "4" });
---

{
  transactions.length === 0 ? (
    <tr>
      <td colspan="7" class={emptyCell}>
        取引がありません
      </td>
    </tr>
  ) : (
    transactions.map((tx) => <TransactionRow transaction={tx} />)
  )
}

<CrudPagination
  currentPage={currentPage}
  totalPages={totalPages}
  pageSize={pageSize}
  baseUrl="/api/transactions"
  bodyTargetId="tx-body"
  paginationId="tx-pagination"
  extraParams={extraParams}
  oob
/>
