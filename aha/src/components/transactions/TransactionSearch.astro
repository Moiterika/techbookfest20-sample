---
import { css } from "../../../styled-system/css";
import { inputStyle, labelStyle } from "../../styles/common.css";

const searchRow = css({
  display: "flex",
  gap: "6",
  flexWrap: "wrap",
  alignItems: "flex-end",
});
---

<div
  id="tx-search"
  class={css({ mb: "6", bg: "white", rounded: "xl", p: "6" })}
>
  <div class={searchRow}>
    <label class={labelStyle}>
      <span>開始日</span>
      <input
        id="tx-date-from"
        type="date"
        name="dateFrom"
        class={inputStyle}
        hx-get="/api/transactions"
        hx-trigger="change"
        hx-target="#tx-body"
        hx-swap="innerHTML"
        hx-include="#tx-search"
        hx-vals='{"page": "1"}'
      />
    </label>
    <label class={labelStyle}>
      <span>終了日</span>
      <input
        id="tx-date-to"
        type="date"
        name="dateTo"
        class={inputStyle}
        hx-get="/api/transactions"
        hx-trigger="change"
        hx-target="#tx-body"
        hx-swap="innerHTML"
        hx-include="#tx-search"
        hx-vals='{"page": "1"}'
      />
    </label>
  </div>
</div>
