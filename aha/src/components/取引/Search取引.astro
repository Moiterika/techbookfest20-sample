---
import { inputStyle, labelStyle } from "../../styles/common";

const searchRow = "flex gap-6 flex-wrap items-end";
---

<div
  id="tx-search"
  class="mb-6 bg-white rounded-xl p-6"
>
  <div class={searchRow}>
    <label class={labelStyle}>
      <span>開始日</span>
      <input
        id="tx-date-from"
        type="date"
        name="dateFrom"
        class={inputStyle}
        hx-get="/api/取引"
        hx-trigger="change"
        hx-target="#tx-body"
        hx-swap="innerHTML"
        hx-include="#tx-search"
        hx-vals='{"page": "1"}'
      />
    </label>
    <label class={labelStyle}>
      <span>終了日</span>
      <input
        id="tx-date-to"
        type="date"
        name="dateTo"
        class={inputStyle}
        hx-get="/api/取引"
        hx-trigger="change"
        hx-target="#tx-body"
        hx-swap="innerHTML"
        hx-include="#tx-search"
        hx-vals='{"page": "1"}'
      />
    </label>
  </div>
</div>
