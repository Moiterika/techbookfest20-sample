---
import { inputStyle, labelStyle } from "../../styles/common";

const searchRow = "flex gap-4 flex-wrap";
---

<div
  id="items-search"
  class="mb-6 bg-white rounded-xl p-6"
>
  <div class={searchRow}>
    <div class={`${labelStyle} flex-1 min-w-[200px]`}>
      <span>検索</span>
      <input
        type="search"
        name="q"
        placeholder="品目コード・品目名で検索…"
        class={inputStyle}
        hx-get="/api/品目"
        hx-trigger="input changed delay:300ms, search"
        hx-target="#items-body"
        hx-swap="innerHTML"
        hx-include="#items-search"
        hx-vals='{"page": "1"}'
      />
    </div>
    <div class={`${labelStyle} min-w-[160px]`}>
      <span>カテゴリ</span>
      <input
        type="search"
        name="category"
        placeholder="カテゴリ"
        class={inputStyle}
        hx-get="/api/品目"
        hx-trigger="input changed delay:300ms, search"
        hx-target="#items-body"
        hx-swap="innerHTML"
        hx-include="#items-search"
        hx-vals='{"page": "1"}'
      />
    </div>
  </div>
</div>
