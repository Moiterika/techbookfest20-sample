---
import Typeahead品目Search from "./Typeahead品目Search.astro";
import Typeahead品目Badge from "./Typeahead品目Badge.astro";

interface Props {
  name?: string;
  selectedId?: number;
  selectedCode?: string;
  selectedName?: string;
  selectedPrice?: number;
  formId?: string;
  compact?: boolean;
  hideNameLabel?: boolean;
  lookupTargetId?: string;
}

const {
  name = "itemId",
  selectedId,
  selectedCode = "",
  selectedName = "",
  selectedPrice,
  formId,
  compact = false,
  hideNameLabel = false,
  lookupTargetId,
} = Astro.props;

const hxVals = JSON.stringify({
  taName: name,
  taFormId: formId ?? "",
  taCompact: String(compact),
  taHideNameLabel: String(hideNameLabel),
  taLookupId: lookupTargetId ?? "",
});

const afterSwapHandler = [
  "const el = this.querySelector('[data-selected-name]');",
  "if (el) {",
  "  const d = { name: el.dataset.selectedName, price: Number(el.dataset.selectedPrice || 0) };",
  "  this.dispatchEvent(new CustomEvent('item-selected', { detail: d, bubbles: true }));",
  "}",
].join(" ");
---

<div
  data-typeahead
  class="relative"
  hx-vals={hxVals}
  hx-target="this"
  hx-get="/api/品目/typeahead?action=clear"
  hx-trigger="typeahead-reset from:body"
  hx-swap="innerHTML"
  hx-disinherit="hx-target"
  hx-on--after-swap={afterSwapHandler}
>
  {
    selectedId ? (
      <Typeahead品目Badge
        name={name}
        selectedId={selectedId}
        selectedCode={selectedCode}
        selectedName={selectedName}
        selectedPrice={selectedPrice}
        formId={formId}
        hideNameLabel={hideNameLabel}
      />
    ) : (
      <Typeahead品目Search name={name} formId={formId} compact={compact} />
    )
  }
</div>
