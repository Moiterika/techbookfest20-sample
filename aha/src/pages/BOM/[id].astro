---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import HeaderBodyForm from "../../components/header-body/HeaderBodyForm.astro";
import { BOMヘッダーボディ } from "../../features/BOM/gen-go.config";
import { pageContainer, pageTitle } from "../../styles/common";
import { db } from "../../db";
import { boms, bomLines, items } from "../../db/schema";
import { eq } from "drizzle-orm";

const config = BOMヘッダーボディ;
const id = Number(Astro.params.id);
if (!id) return Astro.redirect("/BOM");

const showSavedToast = Astro.url.searchParams.has("saved");

const [bom] = await db.select().from(boms).where(eq(boms.id, id)).limit(1);
if (!bom) return Astro.redirect("/BOM");

const lines = await db
  .select({
    id: bomLines.id,
    type: bomLines.type,
    itemId: bomLines.itemId,
    quantity: bomLines.quantity,
    unit: bomLines.unit,
    refBomCode: bomLines.refBomCode,
    refBomVersion: bomLines.refBomVersion,
    itemCode: items.code,
    itemName: items.name,
  })
  .from(bomLines)
  .leftJoin(items, eq(bomLines.itemId, items.id))
  .where(eq(bomLines.bomId, id));

// Build childrenData from config.children discriminator definitions
const childrenData = config.children.map((child) => {
  const disc = child.discriminator;
  const filtered = disc
    ? lines.filter((l) => (l as any)[disc.column] === disc.value)
    : lines;
  return {
    records: filtered.map((l) => ({
      itemId: l.itemId,
      itemCode: l.itemCode || "",
      itemName: l.itemName || "",
      quantity: l.quantity,
      unit: l.unit,
      refBomCode: l.refBomCode || "",
      refBomVersion: l.refBomVersion || "",
    })),
  };
});

const headerValues = {
  code: bom.code,
  version: bom.version,
  name: bom.name,
};
---

<Layout>
  <main class={pageContainer}>
    <Nav current="boms" />
    <h1 class={pageTitle}>BOM編集</h1>
    <HeaderBodyForm
      config={config}
      mode="edit"
      recordId={bom.id}
      headerValues={headerValues}
      childrenData={childrenData}
    />
  </main>
</Layout>

{showSavedToast && <meta data-show-saved />}

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const flag = document.querySelector("meta[data-show-saved]");
    if (!flag) return;
    flag.remove();
    window.dispatchEvent(
      new CustomEvent("show-toast", { detail: { value: "保存しました" } }),
    );
    const url = new URL(window.location.href);
    url.searchParams.delete("saved");
    history.replaceState(null, "", url.pathname);
  });
</script>
