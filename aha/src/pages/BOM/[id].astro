---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import HeaderBodyForm from "../../components/header-body/HeaderBodyForm.astro";
import { BOMヘッダーボディ } from "../../features/BOM/gen-go.config";
import { pageContainer, pageTitle } from "../../styles/common";
import { db } from "../../db";
import { BOMテーブル, BOM明細テーブル, 品目テーブル } from "../../db/schema";
import { eq } from "drizzle-orm";

const config = BOMヘッダーボディ;
const id = Number(Astro.params.id);
if (!id) return Astro.redirect("/BOM");

const showSavedToast = Astro.url.searchParams.has("saved");

const [bom] = await db
  .select()
  .from(BOMテーブル)
  .where(eq(BOMテーブル.ID, id))
  .limit(1);
if (!bom) return Astro.redirect("/BOM");

const lines = await db
  .select({
    id: BOM明細テーブル.ID,
    区分: BOM明細テーブル.区分,
    itemId: BOM明細テーブル.品目ID,
    quantity: BOM明細テーブル.数量,
    unit: BOM明細テーブル.単位,
    refBomCode: BOM明細テーブル.参照BOMコード,
    refBomVersion: BOM明細テーブル.参照BOM版,
    itemCode: 品目テーブル.コード,
    itemName: 品目テーブル.名称,
  })
  .from(BOM明細テーブル)
  .leftJoin(品目テーブル, eq(BOM明細テーブル.品目ID, 品目テーブル.ID))
  .where(eq(BOM明細テーブル.BOM_ID, id));

// Build childrenData from config.children discriminator definitions
const childrenData = config.children.map((child) => {
  const disc = child.discriminator;
  const filtered = disc
    ? lines.filter((l) => (l as any)[disc.column] === disc.value)
    : lines;
  return {
    records: filtered.map((l) => ({
      itemId: l.itemId,
      itemCode: l.itemCode || "",
      itemName: l.itemName || "",
      quantity: l.quantity,
      unit: l.unit,
      refBomCode: l.refBomCode || "",
      refBomVersion: l.refBomVersion || "",
    })),
  };
});

const headerValues = {
  コード: bom.コード,
  版: bom.版,
  名称: bom.名称,
};
---

<Layout>
  <main class={pageContainer}>
    <Nav current="boms" />
    <h1 class={pageTitle}>BOM編集</h1>
    <HeaderBodyForm
      config={config}
      mode="edit"
      recordId={bom.ID}
      headerValues={headerValues}
      childrenData={childrenData}
    />
  </main>
</Layout>

{showSavedToast && <meta data-show-saved />}

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const flag = document.querySelector("meta[data-show-saved]");
    if (!flag) return;
    flag.remove();
    window.dispatchEvent(
      new CustomEvent("show-toast", { detail: { value: "保存しました" } }),
    );
    const url = new URL(window.location.href);
    url.searchParams.delete("saved");
    history.replaceState(null, "", url.pathname);
  });
</script>
