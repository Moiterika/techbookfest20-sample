---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import { css } from "../../styled-system/css";
import {
  pageContainer,
  pageTitle,
  card,
  btnPrimary,
  thCell,
  tdCell,
  row,
} from "../styles/common.css";

const editBtn = css({
  display: "inline-flex",
  alignItems: "center",
  gap: "1",
  color: "#00288e",
  fontSize: "xs",
  fontWeight: "bold",
  px: "2",
  py: "1",
  rounded: "md",
  cursor: "pointer",
  border: "none",
  bg: "transparent",
  textDecoration: "none",
  _hover: { bg: "rgba(0, 40, 142, 0.1)" },
});

const deleteBtn = css({
  display: "inline-flex",
  alignItems: "center",
  gap: "1",
  color: "#ba1a1a",
  fontSize: "xs",
  fontWeight: "bold",
  px: "2",
  py: "1",
  rounded: "md",
  cursor: "pointer",
  border: "none",
  bg: "transparent",
  _hover: { bg: "rgba(186, 26, 26, 0.1)" },
});

const actionsCell = css({
  py: "4",
  px: "6",
  textAlign: "right",
  display: "flex",
  gap: "2",
  justifyContent: "flex-end",
});

const toolbar = css({
  display: "flex",
  justifyContent: "flex-end",
  mb: "4",
});

const emptyRow = css({
  textAlign: "center",
  py: "8",
  color: "#757684",
  fontSize: "sm",
});

const tableWrap = css({
  overflowX: "auto",
  rounded: "xl",
  bg: "white",
});
---

<Layout>
  <main class={pageContainer}>
    <Nav current="boms" />
    <h1 class={pageTitle}>BOM管理</h1>

    <div class={toolbar}>
      <a href="/boms/new" class={btnPrimary}>+ 新規BOM</a>
    </div>

    <div class={tableWrap}>
      <table style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr>
            <th class={thCell}>BOMコード</th>
            <th class={thCell}>版</th>
            <th class={thCell}>名称</th>
            <th class={thCell} style="width: 10rem;">操作</th>
          </tr>
        </thead>
        <tbody
          id="boms-body"
          hx-get="/api/boms"
          hx-trigger="load"
          hx-swap="innerHTML"
        >
          <tr>
            <td colspan="4" class={emptyRow}>読み込み中…</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div id="boms-pagination"></div>
  </main>
</Layout>
