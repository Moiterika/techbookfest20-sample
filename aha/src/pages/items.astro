---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import { pageContainer, pageTitle } from "../styles/common.css";
import CrudToolbar from "../components/crud/CrudToolbar.astro";
import CrudTable from "../components/crud/CrudTable.astro";
import CrudForm from "../components/crud/CrudForm.astro";
import ItemSearch from "../components/items/ItemSearch.astro";
import { itemColumns, itemEntity } from "../features/items";
---

<script>
  import "../components/ReactBarcodeWrapper.tsx";
</script>

<Layout>
  <main class={pageContainer}>
    <Nav current="items" />
    <h1 class={pageTitle}>品目管理</h1>

    <ItemSearch />

    <div x-data="{ open: false }">
      <CrudToolbar
        baseUrl="/api/items"
        bodyTargetId="items-body"
        tableId="items-table"
        searchContainerId="items-search"
      />
      <CrudForm columns={itemColumns} entity={itemEntity} />
    </div>

    <CrudTable
      columns={itemColumns}
      bodyId="items-body"
      baseUrl="/api/items"
      paginationId="items-pagination"
      tableId="items-table"
    />
  </main>
</Layout>
