---
import Layout from "../layouts/Layout.astro";
import { css } from "../../styled-system/css";
import { pageContainer, pageTitle } from "../styles/common.css";
import CrudToolbar from "../components/crud/CrudToolbar.astro";
import CrudTable from "../components/crud/CrudTable.astro";
import HtmxLoading from "../components/crud/HtmxLoading.astro";
import TransactionForm from "../components/transactions/TransactionForm.astro";
import TransactionSearch from "../components/transactions/TransactionSearch.astro";
import type { Column } from "../components/crud/types";

const columns: Column[] = [
  { key: "date", label: "日付" },
  { key: "itemCode", label: "品目コード" },
  { key: "itemName", label: "品目名" },
  { key: "unitPrice", label: "単価", type: "number" },
  { key: "quantity", label: "数量", type: "number" },
  { key: "amount", label: "金額", type: "number" },
  { key: "_actions", label: "操作", width: "32" },
];
---

<Layout>
  <main class={css({ maxWidth: "1000px", mx: "auto", py: "8", px: "4" })}>
    <h1 class={pageTitle}>取引管理</h1>

    <div x-data="{ open: false }">
      <CrudToolbar
        baseUrl="/api/transactions"
        bodyTargetId="tx-body"
        tableId="tx-table"
        searchContainerId="tx-search"
      />
      <TransactionForm />
    </div>

    <TransactionSearch />
    <CrudTable
      columns={columns}
      bodyId="tx-body"
      baseUrl="/api/transactions"
      paginationId="tx-pagination"
      tableId="tx-table"
    />
    <HtmxLoading />
  </main>
</Layout>
