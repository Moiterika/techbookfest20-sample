templ RenderRowsBOM(result ListResultBOM) {
	for _, item := range result.Records {
		@RenderRowBOM(item)
	}
	if len(result.Records) == 0 {
		<tr><td colspan="1" class="text-center py-8 text-outline">BOMがありません</td></tr>
	}
	@RenderPaginationBOM(result)
}

