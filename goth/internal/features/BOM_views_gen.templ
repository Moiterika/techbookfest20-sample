templ RenderEditPageBOM(detail ResponseBOM詳細) {
	@ui.Base("BOM編集") {
		<main class="max-w-[87.5rem] mx-auto py-8 px-8">
			@ui.Nav("boms")
			<h1 class="text-2xl font-bold mb-8 text-on-surface tracking-tight">BOM編集</h1>
			<form hx-put={ fmt.Sprintf("/api/BOM/%d", detail.Id) } hx-swap="innerHTML" hx-target="#bom-error">
				<div id="bom-error" class="min-h-6 mb-2"></div>
				<div class="mb-6 p-6 rounded-xl bg-white">
					<h2 class="text-lg font-bold text-on-surface mb-4 tracking-tight">BOM情報</h2>
					<div class="grid grid-cols-3 gap-4 mb-2">
						<label class="flex flex-col gap-2 text-[0.625rem] font-bold uppercase tracking-wider text-outline">BOMコード<input type="text" name="コード" value={ detail.コード } placeholder="例: BOM-001" required class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white px-3 py-2.5 w-full"/></label>
						<label class="flex flex-col gap-2 text-[0.625rem] font-bold uppercase tracking-wider text-outline">版<input type="text" name="版" value={ detail.版 } placeholder="例: 1" required class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white px-3 py-2.5 w-full"/></label>
						<label class="flex flex-col gap-2 text-[0.625rem] font-bold uppercase tracking-wider text-outline">名称<input type="text" name="名称" value={ detail.名称 } placeholder="例: 製品A 部品表" required class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white px-3 py-2.5 w-full"/></label>
					</div>
				</div>
				<div class="mb-6 p-6 rounded-xl bg-white">
					<div class="text-base font-bold text-on-surface mb-3 flex items-center gap-2"><span class="text-xs font-bold px-2 py-0.5 rounded-full text-white" style="background: #1e40af;">製造品目</span>製造品目（アウトプット）</div>
					<table style="width: 100%; border-collapse: collapse;">
						<thead><tr>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">品目コード</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">品目名</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">数量</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">単位</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest" style="width: 3rem;"></th>
						</tr></thead>
						<tbody id="section-0-lines">
							for _, line := range detail.製造品目アウトプット {
								@RenderExistingLineRowBOM0(line)
							}
						</tbody>
					</table>
					<div style="margin-top: 0.5rem;"><button type="button" class="inline-flex items-center gap-1 text-sm text-primary font-semibold cursor-pointer border-none bg-transparent px-2 py-1.5 rounded-md hover:bg-surface-container-high" hx-get="/api/BOM/line-row?section=0" hx-target="#section-0-lines" hx-swap="beforeend">+ 行追加</button></div>
				</div>
				<div class="mb-6 p-6 rounded-xl bg-white">
					<div class="text-base font-bold text-on-surface mb-3 flex items-center gap-2"><span class="text-xs font-bold px-2 py-0.5 rounded-full text-white" style="background: #b45309;">投入品目</span>投入品目（インプット）</div>
					<table style="width: 100%; border-collapse: collapse;">
						<thead><tr>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">品目コード</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">品目名</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">数量</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">単位</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">BOMコード</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">版</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest" style="width: 3rem;"></th>
						</tr></thead>
						<tbody id="section-1-lines">
							for _, line := range detail.投入品目インプット {
								@RenderExistingLineRowBOM1(line)
							}
						</tbody>
					</table>
					<div style="margin-top: 0.5rem;"><button type="button" class="inline-flex items-center gap-1 text-sm text-primary font-semibold cursor-pointer border-none bg-transparent px-2 py-1.5 rounded-md hover:bg-surface-container-high" hx-get="/api/BOM/line-row?section=1" hx-target="#section-1-lines" hx-swap="beforeend">+ 行追加</button></div>
				</div>
				<div class="flex gap-3 justify-end mt-6">
					<a href="/BOM" class="text-sm py-2 px-4 rounded-lg cursor-pointer font-semibold transition-all duration-200 inline-flex items-center justify-center border-none bg-transparent text-primary hover:bg-surface-container-high active:bg-surface-container-highest">キャンセル</a>
					<button type="submit" class="text-sm py-2 px-4 rounded-lg cursor-pointer font-semibold transition-all duration-200 inline-flex items-center justify-center border-none bg-gradient-to-br from-primary to-primary-dark text-white hover:opacity-90 active:opacity-80">更新</button>
				</div>
			</form>
		</main>
		@ui.Notifications()
	}
}

templ RenderExistingLineRowBOM0(line BOM明細) {
	<tr class="transition-all duration-200 ease-in-out hover:bg-surface-container-low [&.htmx-swapping]:opacity-0">
		<input type="hidden" name="line区分" value="2"/>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderTypeahead品目("line品目ID", line.品目ID, line.品目コード, line.品目名, true, true, fmt.Sprintf("lookup-%d-itemName", line.Id))</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><span id={ fmt.Sprintf("lookup-%d-itemName", line.Id) } class="text-sm text-outline">{ line.品目名 }</span></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="number" step="0.0001" name="line数量" value={ line.数量 } class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderSelectLineBOM0単位(line.単位)</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm" style="width: 3rem;"><button type="button" class="inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-error border-none bg-transparent text-sm hover:bg-error/10" onclick="this.closest('tr').remove()">&times;</button></td>
	</tr>
}

templ RenderExistingLineRowBOM1(line BOM明細) {
	<tr class="transition-all duration-200 ease-in-out hover:bg-surface-container-low [&.htmx-swapping]:opacity-0">
		<input type="hidden" name="line区分" value="1"/>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderTypeahead品目("line品目ID", line.品目ID, line.品目コード, line.品目名, true, true, fmt.Sprintf("lookup-%d-itemName", line.Id))</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><span id={ fmt.Sprintf("lookup-%d-itemName", line.Id) } class="text-sm text-outline">{ line.品目名 }</span></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="number" step="0.0001" name="line数量" value={ line.数量 } class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderSelectLineBOM1単位(line.単位)</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="text" name="line参照BOMコード" value={ NullStrOr(line.参照BOMコード, "") } class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="text" name="line参照BOM版" value={ NullStrOr(line.参照BOM版, "") } class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm" style="width: 3rem;"><button type="button" class="inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-error border-none bg-transparent text-sm hover:bg-error/10" onclick="this.closest('tr').remove()">&times;</button></td>
	</tr>
}

templ RenderSelectLineBOM0単位(selected string) {
	<select name="line単位" class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 min-w-20">
		<option value="pcs" if selected == "pcs" { selected }>個</option>
		<option value="kg" if selected == "kg" { selected }>kg</option>
		<option value="g" if selected == "g" { selected }>g</option>
		<option value="L" if selected == "L" { selected }>L</option>
		<option value="mL" if selected == "mL" { selected }>mL</option>
		<option value="m" if selected == "m" { selected }>m</option>
		<option value="cm" if selected == "cm" { selected }>cm</option>
		<option value="box" if selected == "box" { selected }>箱</option>
		<option value="set" if selected == "set" { selected }>セット</option>
		<option value="hour" if selected == "hour" { selected }>時間</option>
	</select>
}

templ RenderSelectLineBOM1単位(selected string) {
	<select name="line単位" class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 min-w-20">
		<option value="pcs" if selected == "pcs" { selected }>個</option>
		<option value="kg" if selected == "kg" { selected }>kg</option>
		<option value="g" if selected == "g" { selected }>g</option>
		<option value="L" if selected == "L" { selected }>L</option>
		<option value="mL" if selected == "mL" { selected }>mL</option>
		<option value="m" if selected == "m" { selected }>m</option>
		<option value="cm" if selected == "cm" { selected }>cm</option>
		<option value="box" if selected == "box" { selected }>箱</option>
		<option value="set" if selected == "set" { selected }>セット</option>
		<option value="hour" if selected == "hour" { selected }>時間</option>
	</select>
}

templ RenderEmptyLineRowBOM0(rowKey string) {
	<tr class="transition-all duration-200 ease-in-out hover:bg-surface-container-low [&.htmx-swapping]:opacity-0">
		<input type="hidden" name="line区分" value="2"/>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderTypeahead品目("line品目ID", 0, "", "", true, true, fmt.Sprintf("lookup-%s-itemName", rowKey))</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><span id={ fmt.Sprintf("lookup-%s-itemName", rowKey) } class="text-sm text-outline"></span></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="number" step="0.0001" min="0" name="line数量" placeholder="0" class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderSelectLineBOM0単位("pcs")</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm" style="width: 3rem;"><button type="button" class="inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-error border-none bg-transparent text-sm hover:bg-error/10" onclick="this.closest('tr').remove()">&times;</button></td>
	</tr>
}

templ RenderEmptyLineRowBOM1(rowKey string) {
	<tr class="transition-all duration-200 ease-in-out hover:bg-surface-container-low [&.htmx-swapping]:opacity-0">
		<input type="hidden" name="line区分" value="1"/>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderTypeahead品目("line品目ID", 0, "", "", true, true, fmt.Sprintf("lookup-%s-itemName", rowKey))</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><span id={ fmt.Sprintf("lookup-%s-itemName", rowKey) } class="text-sm text-outline"></span></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="number" step="0.0001" min="0" name="line数量" placeholder="0" class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">@RenderSelectLineBOM1単位("pcs")</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="text" name="line参照BOMコード" placeholder="BOMコード" class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="text" name="line参照BOM版" placeholder="版" class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm" style="width: 3rem;"><button type="button" class="inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-error border-none bg-transparent text-sm hover:bg-error/10" onclick="this.closest('tr').remove()">&times;</button></td>
	</tr>
}

templ RenderLineRowBOM(section int, rowKey string) {
	if section == 0 {
		@RenderEmptyLineRowBOM0(rowKey)
	} else if section == 1 {
		@RenderEmptyLineRowBOM1(rowKey)
	}
}
