templ RenderPageBOM() {
	@ui.Base("BOM管理") {
		<main class="max-w-[87.5rem] mx-auto py-8 px-8">
			@ui.Nav("boms")
			<h1 class="text-2xl font-bold mb-8 text-on-surface tracking-tight">BOM管理</h1>
			<div class="flex justify-end mb-4">
				<a href="/BOM/new" class="text-sm py-2 px-4 rounded-lg cursor-pointer font-semibold transition-all duration-200 inline-flex items-center justify-center border-none bg-gradient-to-br from-primary to-primary-dark text-white hover:opacity-90 active:opacity-80">+ 新規BOM登録</a>
			</div>
			<div class="overflow-x-auto rounded-xl bg-white">
				<table style="width: 100%; border-collapse: collapse;">
					<thead>
						<tr>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">BOMコード</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">版</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest">名称</th>
							<th class="py-4 px-6 text-[0.625rem] font-bold text-on-surface-variant uppercase tracking-widest" style="width: 10rem;">操作</th>
						</tr>
					</thead>
					<tbody id="boms-body" hx-get="/api/BOM" hx-trigger="load" hx-swap="innerHTML"></tbody>
				</table>
			</div>
			<div id="boms-pagination"></div>
		</main>
		@ui.Notifications()
	}
}

templ RenderRowBOM(item ResponseBOM) {
	<tr id={ fmt.Sprintf("bom-%d", item.Id) } class="transition-all duration-200 ease-in-out hover:bg-surface-container-low [&.htmx-swapping]:opacity-0">
		<td class="py-4 px-6 text-on-surface-variant text-sm">{ item.コード }</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">{ item.版 }</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">{ item.名称 }</td>
		<td class="py-4 px-6 text-right">
			<div class="flex items-center justify-end gap-2">
				<a href={ fmt.Sprintf("/BOM/%d", item.Id) } class="inline-flex items-center gap-1 text-primary text-xs font-bold px-2 py-1 rounded-md cursor-pointer border-none bg-transparent no-underline hover:bg-primary/10 no-underline">
					@ui.Icon("pencil-square", "w-3.5 h-3.5")
					編集
				</a>
				<div class="relative" x-data="{ menuOpen: false }" @click.outside="menuOpen = false">
					<button class="inline-flex items-center justify-center w-7 h-7 rounded-full cursor-pointer text-outline border-none bg-transparent hover:text-on-surface hover:bg-surface-container-low" @click="menuOpen = !menuOpen" type="button">
						@ui.Icon("ellipsis-vertical-solid", "w-5 h-5")
					</button>
					<div class="absolute right-0 top-full z-20 mt-1 bg-white rounded-lg shadow-[0_10px_30px_-5px_rgba(18,28,42,0.08)] py-1 min-w-[120px]" x-show="menuOpen" x-transition x-cloak>
						<button class="flex items-center gap-2 w-full text-left px-3 py-2 text-sm cursor-pointer text-error border-none bg-transparent hover:bg-error-container/30" hx-delete={ fmt.Sprintf("/api/BOM/%d", item.Id) } hx-target={ fmt.Sprintf("#bom-%d", item.Id) } hx-swap="outerHTML swap:0.3s" hx-confirm="「{名称}」を削除しますか？" @click="menuOpen = false">
							@ui.Icon("trash", "w-4 h-4")
							削除
						</button>
					</div>
				</div>
			</div>
		</td>
	</tr>
}

templ RenderRowsBOM(result ListResultBOM) {
	for _, item := range result.Records {
		@RenderRowBOM(item)
	}
	if len(result.Records) == 0 {
		<tr><td colspan="4" class="text-center py-8 text-outline">BOMがありません</td></tr>
	}
	@RenderPaginationBOM(result)
}

templ RenderPaginationBOM(result ListResultBOM) {
	<div id="boms-pagination" hx-swap-oob="true" class="flex justify-between items-center py-4 px-6 bg-surface-container-low rounded-b-xl flex-wrap gap-3">
		<div class="flex items-center gap-2 text-sm text-on-surface-variant">
			<span>表示件数:</span>
			<select name="size" hx-get="/api/BOM" hx-target="#boms-body" hx-swap="innerHTML" hx-include="this" hx-vals='{"page": "1"}' class="bg-white rounded-md text-sm py-1 px-2 text-on-surface-variant border-none cursor-pointer outline-none focus:shadow-[0_0_0_1px_var(--color-primary)]">
				<option value="20" if result.PageSize == 20 { selected }>20件</option>
				<option value="50" if result.PageSize == 50 { selected }>50件</option>
				<option value="100" if result.PageSize == 100 { selected }>100件</option>
			</select>
		</div>
		if result.TotalPages > 1 {
			<div class="flex items-center gap-1">
				if result.CurrentPage > 1 {
					<button class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg cursor-pointer text-on-surface hover:bg-surface-container-high border-none" hx-get={ fmt.Sprintf("/api/BOM?page=%d&size=%d", result.CurrentPage-1, result.PageSize) } hx-target="#boms-body" hx-swap="innerHTML">&#8249;</button>
				} else {
					<span class="w-8 h-8 flex items-center justify-center text-xs rounded-lg text-outline-variant cursor-default border-none">&#8249;</span>
				}
				for i := 1; i <= result.TotalPages; i++ {
					if i == result.CurrentPage {
						<span class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg bg-gradient-to-br from-primary to-primary-dark text-white cursor-default border-none">{ fmt.Sprintf("%d", i) }</span>
					} else {
						<button class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg cursor-pointer text-on-surface hover:bg-surface-container-high border-none" hx-get={ fmt.Sprintf("/api/BOM?page=%d&size=%d", i, result.PageSize) } hx-target="#boms-body" hx-swap="innerHTML">{ fmt.Sprintf("%d", i) }</button>
					}
				}
				if result.CurrentPage < result.TotalPages {
					<button class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg cursor-pointer text-on-surface hover:bg-surface-container-high border-none" hx-get={ fmt.Sprintf("/api/BOM?page=%d&size=%d", result.CurrentPage+1, result.PageSize) } hx-target="#boms-body" hx-swap="innerHTML">&#8250;</button>
				} else {
					<span class="w-8 h-8 flex items-center justify-center text-xs rounded-lg text-outline-variant cursor-default border-none">&#8250;</span>
				}
				<span class="text-sm font-medium text-outline ml-4">{ fmt.Sprintf("%d", result.CurrentPage) } / { fmt.Sprintf("%d", result.TotalPages) } ページ</span>
			</div>
		} else {
			<div class="flex items-center gap-1">
				<span class="text-sm font-medium text-outline">全 { fmt.Sprintf("%d", result.TotalPages) } ページ</span>
			</div>
		}
	</div>
}

