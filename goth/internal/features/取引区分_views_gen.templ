templ RenderRows取引区分(result ListResult取引区分) {
	for _, item := range result.Records {
		@RenderRow取引区分(item)
	}
	if len(result.Records) == 0 {
		<tr><td colspan="5" class="text-center py-8 text-outline">取引区分がありません</td></tr>
	}
	@RenderPagination取引区分(result)
}

templ RenderPagination取引区分(result ListResult取引区分) {
	<div id="txtypes-pagination" hx-swap-oob="true" class="flex justify-between items-center py-4 px-6 bg-surface-container-low rounded-b-xl flex-wrap gap-3">
		<div class="flex items-center gap-2 text-sm text-on-surface-variant">
			<span>表示件数:</span>
			<select name="size" hx-get="/api/取引区分" hx-target="#txtypes-body" hx-swap="innerHTML" hx-include="this" hx-vals='{"page": "1"}' class="bg-white rounded-md text-sm py-1 px-2 text-on-surface-variant border-none cursor-pointer outline-none focus:shadow-[0_0_0_1px_var(--color-primary)]">
				<option value="20" if result.PageSize == 20 { selected }>20件</option>
				<option value="50" if result.PageSize == 50 { selected }>50件</option>
				<option value="100" if result.PageSize == 100 { selected }>100件</option>
			</select>
		</div>
		if result.TotalPages > 1 {
			<div class="flex items-center gap-1">
				if result.CurrentPage > 1 {
					<button class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg cursor-pointer text-on-surface hover:bg-surface-container-high border-none" hx-get={ fmt.Sprintf("/api/取引区分?page=%d&size=%d", result.CurrentPage-1, result.PageSize) } hx-target="#txtypes-body" hx-swap="innerHTML">&#8249;</button>
				} else {
					<span class="w-8 h-8 flex items-center justify-center text-xs rounded-lg text-outline-variant cursor-default border-none">&#8249;</span>
				}
				for i := 1; i <= result.TotalPages; i++ {
					if i == result.CurrentPage {
						<span class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg bg-gradient-to-br from-primary to-primary-dark text-white cursor-default border-none">{ fmt.Sprintf("%d", i) }</span>
					} else {
						<button class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg cursor-pointer text-on-surface hover:bg-surface-container-high border-none" hx-get={ fmt.Sprintf("/api/取引区分?page=%d&size=%d", i, result.PageSize) } hx-target="#txtypes-body" hx-swap="innerHTML">{ fmt.Sprintf("%d", i) }</button>
					}
				}
				if result.CurrentPage < result.TotalPages {
					<button class="w-8 h-8 flex items-center justify-center text-xs font-bold rounded-lg cursor-pointer text-on-surface hover:bg-surface-container-high border-none" hx-get={ fmt.Sprintf("/api/取引区分?page=%d&size=%d", result.CurrentPage+1, result.PageSize) } hx-target="#txtypes-body" hx-swap="innerHTML">&#8250;</button>
				} else {
					<span class="w-8 h-8 flex items-center justify-center text-xs rounded-lg text-outline-variant cursor-default border-none">&#8250;</span>
				}
				<span class="text-sm font-medium text-outline ml-4">{ fmt.Sprintf("%d", result.CurrentPage) } / { fmt.Sprintf("%d", result.TotalPages) } ページ</span>
			</div>
		} else {
			<div class="flex items-center gap-1">
				<span class="text-sm font-medium text-outline">全 { fmt.Sprintf("%d", result.TotalPages) } ページ</span>
			</div>
		}
	</div>
}
