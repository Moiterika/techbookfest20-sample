templ RenderEditRow取引区分(item Response取引区分) {
	<tr id={ fmt.Sprintf("txtype-%d", item.Id) } class="bg-surface-container-low">
		<td class="py-4 px-6 w-10"></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="text" name="コード" value={ item.コード } form={ fmt.Sprintf("edit-form-%d", item.Id) } class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><input type="text" name="名称" value={ item.名称 } form={ fmt.Sprintf("edit-form-%d", item.Id) } class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><select name="係数" form={ fmt.Sprintf("edit-form-%d", item.Id) } class="rounded-lg text-sm text-on-surface outline-none bg-surface-container-low border-2 border-transparent transition-[border-color,background-color] duration-200 focus:border-b-primary focus:bg-white py-1.5 px-2.5 w-full min-w-[7.5rem]"><option value="1" if fmt.Sprintf("%v", item.係数) == "1" { selected }>入庫</option><option value="0" if fmt.Sprintf("%v", item.係数) == "0" { selected }>なし</option><option value="-1" if fmt.Sprintf("%v", item.係数) == "-1" { selected }>出庫</option></select></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">
			<div class="flex gap-2">
				<button class="text-sm py-2 px-4 rounded-lg cursor-pointer font-semibold transition-all duration-200 inline-flex items-center justify-center border-none bg-gradient-to-br from-primary to-primary-dark text-white hover:opacity-90 active:opacity-80" hx-put={ fmt.Sprintf("/api/取引区分/%d", item.Id) } hx-target={ fmt.Sprintf("#txtype-%d", item.Id) } hx-swap="outerHTML" hx-include={ fmt.Sprintf("#edit-form-%d", item.Id) }>保存</button>
