templ RenderRow品目(item Response品目) {
	<tr id={ fmt.Sprintf("item-%d", item.Id) } class="transition-all duration-200 ease-in-out hover:bg-surface-container-low [&.htmx-swapping]:opacity-0">
		<td class="py-4 px-6 w-10"><input type="checkbox" name="rowSelect" value={ fmt.Sprintf("%d", item.Id) } class="rounded-sm cursor-pointer accent-primary"/></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">{ item.Code }</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">{ item.Name }</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">{ NullStrOr(item.Category, "-") }</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">{ fmt.Sprintf("%d", item.Price) }</td>
		<td class="py-4 px-6 text-on-surface-variant text-sm"><div class="flex flex-col gap-1">{ NullStrOr(item.Barcode, "-") }<react-barcode value={ NullStrOr(item.Barcode, "") }></react-barcode></div></td>
		<td class="py-4 px-6 text-on-surface-variant text-sm">
			<div class="flex gap-2">
				<button class="text-sm py-2 px-4 rounded-lg cursor-pointer font-semibold transition-all duration-200 inline-flex items-center justify-center border-none bg-transparent text-primary hover:bg-surface-container-high active:bg-surface-container-highest" hx-get={ fmt.Sprintf("/api/品目/%d/edit", item.Id) } hx-target={ fmt.Sprintf("#item-%d", item.Id) } hx-swap="outerHTML">編集</button>
				<button class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-150 text-error bg-error-container/20 border-none hover:bg-error-container/40 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-error-container/20" hx-delete={ fmt.Sprintf("/api/品目/%d", item.Id) } hx-target={ fmt.Sprintf("#item-%d", item.Id) } hx-swap="outerHTML swap:0.3s" hx-confirm="「{name}」を削除しますか？">削除</button>
			</div>
		</td>
	</tr>
}

